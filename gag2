-- v32.8: SEMBUNYIIN BUAH GEDE - buah >= N kg (default 100) dihilangin TOTAL (transparan 1).
-- beda dari v11.8: yg ilang CUMA buah berat (mesh paling gede = beban render terbesar), sisanya tetep keliatan.
-- pakai attr sendiri (ZenxOrigTB) biar ga tabrakan sama fitur Sembunyiin Buah biasa.
Farm._hideBigOn = false
function Farm.hideBigFruitParts(fruit, hide)
    local function setT(d)
        if hide then
            if d:GetAttribute("ZenxOrigTB") == nil then d:SetAttribute("ZenxOrigTB", d.Transparency) end
            d.Transparency = 1
        else
            local o = d:GetAttribute("ZenxOrigTB")
            if type(o) == "number" then d.Transparency = o end
            d:SetAttribute("ZenxOrigTB", nil)
        end
    end
    -- v32.9: prompt Harvest (ProximityPrompt) & ClickDetector ikut dimatiin biar buah yg ilang
    -- BENERAN gak bisa ke-harvest/kepencet manual. dibalikin persis pas unhide.
    local function setInteract(d)
        if d:IsA("ProximityPrompt") then
            if hide then
                if d:GetAttribute("ZenxOrigPE") == nil then d:SetAttribute("ZenxOrigPE", d.Enabled) end
                d.Enabled = false
            else
                local o = d:GetAttribute("ZenxOrigPE")
                if o ~= nil then d.Enabled = (o == true) end
                d:SetAttribute("ZenxOrigPE", nil)
            end
        elseif d:IsA("ClickDetector") then
            if hide then
                if d:GetAttribute("ZenxOrigCD") == nil then d:SetAttribute("ZenxOrigCD", d.MaxActivationDistance) end
                d.MaxActivationDistance = 0
            else
                local o = d:GetAttribute("ZenxOrigCD")
                if type(o) == "number" then d.MaxActivationDistance = o end
                d:SetAttribute("ZenxOrigCD", nil)
            end
        end
    end
    pcall(function()
        for _, d in ipairs(fruit:GetDescendants()) do
            if d:IsA("BasePart") or d:IsA("Decal") or d:IsA("Texture") then setT(d)
            else setInteract(d) end
        end
        if fruit:IsA("BasePart") then setT(fruit) end
    end)
end
function Farm.scanHideBigFruits(on)
    local gardens = workspace:FindFirstChild("Gardens"); if not gardens then return end
    local thr = tonumber(state.hideBigKg) or 100
    local cnt = 0
    for _, plot in ipairs(gardens:GetChildren()) do
        local plants = plot:FindFirstChild("Plants")
        if plants then
            for _, plant in ipairs(plants:GetChildren()) do
                local seedName = plant:GetAttribute("SeedName") or plant.Name
                local fr = plant:FindFirstChild("Fruits")
                if fr then
                    for _, fruit in ipairs(fr:GetChildren()) do
                        if on then
                            local kg = Farm.gardenKg(fruit, seedName) or 0
                            -- >= thr: ilangin. < thr: balikin kalau sempet ke-hide (mis. threshold dinaikin)
                            Farm.hideBigFruitParts(fruit, kg >= thr)
                        else
                            Farm.hideBigFruitParts(fruit, false)   -- restore (cuma yg bertanda ZenxOrigTB)
                        end
                        cnt = cnt + 1
                        if cnt % 30 == 0 then task.wait() end  -- napas biar ga freeze
                    end
                end
            end
        end
    end
end
function Farm.setHideBigFruits(on)
    Farm._hideBigOn = on
    if on then
        task.spawn(function()
            while Farm._hideBigOn and isCurrentGen() do
                pcall(function() Farm.scanHideBigFruits(true) end)
                task.wait(8)   -- rescan: buah yg BARU nyampe berat ikut ilang (buah kan tumbuh)
