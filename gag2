-- ===== HOP: cari server lain lalu pindah =====
-- v5.5: FIX "balik ke server sama". penyebab dulu: kalau scan server gagal (API
-- rate-limit) -> jatuh ke TS:Teleport biasa yg GAK exclude server skrg -> sering balik.
-- sekarang: retry scan beberapa kali; kalau tetap gagal, JANGAN teleport biasa
-- (lebih baik gak hop daripada balik ke server yg sama).
local function doHop()
    local TS = game:GetService("TeleportService")
    local plr = Players.LocalPlayer
    local placeId = game.PlaceId
    local currentJob = tostring(game.JobId)
    print("[ZenxFarm] hop... cari server lain")

    -- ambil JSON: coba request executor dulu (andal buat API eksternal), fallback HttpGet
    local function httpGetJson(url)
        local req = (syn and syn.request) or (http and http.request) or http_request or request
            or (fluxus and fluxus.request)
        if req then
            local ok, resp = pcall(function() return req({ Url = url, Method = "GET",
                Headers = { ["User-Agent"] = "Roblox/WinInet", ["Content-Type"] = "application/json" } }) end)
            if ok and resp then
                local body = resp.Body or resp.body
                local code = resp.StatusCode or resp.Status or resp.status_code
                if body and (not code or code == 200) then
                    local ok2, dec = pcall(function() return HS:JSONDecode(body) end)
                    if ok2 then return dec end
                elseif code then
                    Farm._hopLastErr = "HTTP "..tostring(code)
                end
            end
        end
        -- fallback HttpGet
        local ok, dec = pcall(function() return HS:JSONDecode(game:HttpGet(url)) end)
        if ok then return dec end
        Farm._hopLastErr = Farm._hopLastErr or "HttpGet gagal"
        return nil
    end

    local function scanServers()
        local candidates = {}
        local cursor = nil
        for page = 1, 5 do
            local url = "https://games.roblox.com/v1/games/"..placeId.."/servers/Public?sortOrder=Desc&limit=100"
            if cursor then url = url .. "&cursor=" .. cursor end
            local body = httpGetJson(url)
            if not body or not body.data then break end
            for _, s in ipairs(body.data) do
                local pl = s.playing or 0
                local maxP = s.maxPlayers or 6
                -- bukan server skrg + masih ada slot
                if tostring(s.id) ~= currentJob and (maxP - pl) >= 2 then
                    candidates[#candidates+1] = s
                end
            end
            cursor = body.nextPageCursor
            if not cursor or cursor == "" then break end
        end
        return candidates
    end

    -- retry scan: API server-list sering rate-limit; coba sampai 4x dgn jeda
    local candidates = {}
    for attempt = 1, 4 do
        Farm._hopLastErr = nil
        candidates = scanServers()
        if #candidates > 0 then break end
        print("[ZenxFarm] scan kosong ("..(Farm._hopLastErr or "?").."), retry "..attempt.."/4...")
        task.wait(2)
    end

    if #candidates > 0 then
        -- pilih random dari kandidat (biar multi-akun gak numpuk di server sama)
        pcall(function() math.randomseed(tick() + (tonumber(tostring(game.JobId):gsub("%D","")) or 0)) end)
        -- v5.6: coba beberapa kandidat berbeda. kalau teleport ke satu server gagal
        -- (penuh/mati/basi), langsung coba kandidat lain - jangan nyerah di 1 percobaan.
        -- log error-nya juga (dulu ketelan pcall -> keliatan "pindah" padahal gagal).
        pcall(function() math.randomseed(tick() + (tonumber(tostring(game.JobId):gsub("%D","")) or 0)) end)
        -- acak urutan kandidat
        for i = #candidates, 2, -1 do
            local j = math.random(1, i)
            candidates[i], candidates[j] = candidates[j], candidates[i]
        end
        local tries = math.min(#candidates, 5)
        for i = 1, tries do
            local pick = candidates[i]
            print(string.format("[ZenxFarm] coba %d/%d -> server %s (%d/%d)",
                i, tries, tostring(pick.id):sub(1,8), pick.playing or 0, pick.maxPlayers or 0))
            -- v6.6: pakai izin teleport kita (zenxTeleport) biar gak keblok anti-kepental
            local zt = (typeof(getgenv)=="function" and getgenv() or _G).ZenxTeleport
            local ok, err = pcall(function()
                if zt then
                    return zt(function() TS:TeleportToPlaceInstance(placeId, pick.id, plr) end)
                else
                    return TS:TeleportToPlaceInstance(placeId, pick.id, plr)
                end
            end)
            if ok then
                task.wait(3)  -- kasih waktu teleport mulai; kalau beneran jalan, script bakal di-kill
                print("[ZenxFarm] teleport ke "..tostring(pick.id):sub(1,8).." dikirim (nunggu pindah...)")
                return true
            else
                print("[ZenxFarm] GAGAL teleport ke server itu: "..tostring(err).." -> coba lain")
            end
        end
    end
    -- v19.8: server-list gak kebaca -> FALLBACK rejoin (TeleportService:Teleport).
    -- biasanya dapet server lain; lebih baik daripada gak hop sama sekali.
    print("[ZenxFarm] server-list gak kebaca ("..(Farm._hopLastErr or "?").."), fallback rejoin...")
    local zt2 = (typeof(getgenv)=="function" and getgenv() or _G).ZenxTeleport
    local ok2, err2 = pcall(function()
        if zt2 then return zt2(function() TS:Teleport(placeId, plr) end)
        else return TS:Teleport(placeId, plr) end
    end)
    if ok2 then
        task.wait(3)
        print("[ZenxFarm] fallback rejoin dikirim (nunggu pindah...)")
        return true
    end
    print("[ZenxFarm] fallback rejoin GAGAL juga: "..tostring(err2))
    return false
end

-- v27.6: REJOIN SIMPEL (persis cara sc lain): Teleport(placeId, player) - Roblox pilih server sendiri.
-- skip nyari server-list (yg lambat/rate-limit). pakai izin ZenxTeleport biar ga ke-block hook kita.
-- v35.9: rejoin ke SERVER YANG SAMA - TeleportToPlaceInstance + JobId yg disimpen SEBELUM
-- kick. Teleport(placeId) doang = matchmaking ke server ACAK (keluhan user: habis freeze
