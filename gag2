local function openTypePicker(titleTxt, listFn, selSet, allKey, onChange, countFn)
    local ov = mk("Frame", { Size = UDim2.new(1,0,1,0), BackgroundColor3 = Color3.new(0,0,0),
        BackgroundTransparency = 0.4, ZIndex = 50, BorderSizePixel = 0, Parent = main })
    local bgc = mk("TextButton", { Size = UDim2.new(1,0,1,0), BackgroundTransparency = 1, Text = "",
        AutoButtonColor = false, ZIndex = 50, Parent = ov })
    bgc.MouseButton1Click:Connect(function() ov:Destroy() end)
    local boxF = mk("Frame", { Size = UDim2.new(0, 300, 0, 360), Position = UDim2.new(0.5,0,0.5,0),
        AnchorPoint = Vector2.new(0.5,0.5), BackgroundColor3 = C.bg, BorderSizePixel = 0, ZIndex = 51, Parent = ov })
    corner(boxF, 8)
    local tl = lbl(boxF, titleTxt, 13, C.accent, Enum.TextXAlignment.Left)
    tl.Position = UDim2.new(0,10,0,6); tl.Size = UDim2.new(1,-20,0,24); tl.ZIndex = 52; tl.Font = FONT_B
    local search = mk("TextBox", { Size = UDim2.new(1,-20,0,26), Position = UDim2.new(0,10,0,32),
        BackgroundColor3 = C.card, Text = "", PlaceholderText = "cari...", TextColor3 = C.text,
        Font = FONT, TextSize = 12, BorderSizePixel = 0, ClearTextOnFocus = false, ZIndex = 52, Parent = boxF })
    corner(search, 4)
    local allBtn = mk("TextButton", { Size = UDim2.new(1, -20, 0, 28), Position = UDim2.new(0, 10, 0, 64),
        BackgroundColor3 = C.card, Text = "", AutoButtonColor = false, BorderSizePixel = 0, ZIndex = 52, Parent = boxF })
    corner(allBtn, 6)
    local allL = lbl(allBtn, "", 12, C.text, Enum.TextXAlignment.Center); allL.Size = UDim2.new(1,0,1,0); allL.ZIndex = 53
    if not allKey then allBtn.Visible = false end  -- v8.1: gak ada opsi "Semua" kalau allKey nil
    local sc = mk("ScrollingFrame", { Size = UDim2.new(1,-20,1,-104), Position = UDim2.new(0,10,0,98),
        BackgroundTransparency = 1, ScrollBarThickness = 3, BorderSizePixel = 0, ZIndex = 52, Parent = boxF })
    local scl = mk("UIListLayout", { Padding = UDim.new(0,3), Parent = sc })
    local function updAll()
        if not allKey then return end
        allBtn.BackgroundColor3 = state[allKey] and C.green or C.card
        allL.Text = (state[allKey] and "v " or "   ").."Semua"
        allL.TextColor3 = state[allKey] and Color3.new(0,0,0) or C.text
    end
    local rebuild
    rebuild = function(q)
        for _, ch in ipairs(sc:GetChildren()) do if ch:IsA("TextButton") then ch:Destroy() end end
        q = (q or ""):lower()
        local counts = countFn and countFn() or nil  -- v7.0: jumlah per item (opsional)
        local items = {}
        for _, name in ipairs(listFn()) do
            if q == "" or name:lower():find(q, 1, true) then items[#items+1] = name end
        end
        if countFn then
            -- v7.0: ada count -> JANGAN sort alfabet. pertahankan urutan listFn
            -- (udah terurut terbanyak dulu). yg dipilih tetap naik ke atas.
            local order = {}; for i, n in ipairs(items) do order[n] = i end
            table.sort(items, function(a, b)
                local sa, sb = (selSet[a] == true), (selSet[b] == true)
                if sa ~= sb then return sa end
                return (order[a] or 0) < (order[b] or 0)  -- pertahankan urutan terbanyak
            end)
        else
            -- v5.9: urutkan yg DIPILIH ke atas dulu, sisanya alfabet
            table.sort(items, function(a, b)
                local sa, sb = (selSet[a] == true), (selSet[b] == true)
                if sa ~= sb then return sa end
                return a:lower() < b:lower()
            end)
        end
        for _, name in ipairs(items) do
            do
                local on = selSet[name] == true
                -- v7.0: label + jumlah (mis "Carrot (12)")
                local labelText = name
                if counts then labelText = name.." ("..(counts[name] or 0)..")" end
                local r = mk("TextButton", { Size = UDim2.new(1,0,0,26), BackgroundColor3 = on and C.card or C.panel,
                    Text = (on and "v " or "   ")..labelText, TextColor3 = on and C.accent or C.text,
                    Font = FONT, TextSize = 12, TextXAlignment = Enum.TextXAlignment.Left,
                    BorderSizePixel = 0, AutoButtonColor = false, ZIndex = 53, Parent = sc })
                corner(r, 4)
                r.MouseButton1Click:Connect(function()
                    if selSet[name] then selSet[name] = nil else selSet[name] = true end
                    if allKey then state[allKey] = false end
                    saveState(); updAll(); rebuild(search.Text); onChange()
                    -- log biar keliatan pilihan kesimpan
                    local cur = {}; for nm in pairs(selSet) do cur[#cur+1] = nm end
                    print("[ZenxFarm] pilihan tersimpan: "..(#cur>0 and table.concat(cur,", ") or "(kosong)"))
                end)
            end
        end
        sc.CanvasSize = UDim2.new(0,0,0,scl.AbsoluteContentSize.Y + 8)
    end
    allBtn.MouseButton1Click:Connect(function()
        if not allKey then return end
        state[allKey] = not state[allKey]; saveState(); updAll(); onChange()
    end)
    search:GetPropertyChangedSignal("Text"):Connect(function() rebuild(search.Text) end)
    updAll(); rebuild("")
end

-- ===== helper: baris "Jenis X" + tombol pilih, di dalam body =====
local function mkTypeRow(body, y, labelTxt, listFn, selSet, allKey, allLabel, countFn)
    lbl(body, labelTxt, 13, C.text, Enum.TextXAlignment.Left).Position = UDim2.new(0,0,0,y)
    local btn = mk("TextButton", { Size = UDim2.new(0.58, 0, 0, 28), Position = UDim2.new(0.42, 0, 0, y-3),
        BackgroundColor3 = C.input, Text = "", AutoButtonColor = false, BorderSizePixel = 0, Parent = body })
    corner(btn, 6); stroke(btn, C.border, 1)
    local btnL = lbl(btn, "", 12, C.text, Enum.TextXAlignment.Left)
    btnL.Position = UDim2.new(0, 8, 0, 0); btnL.Size = UDim2.new(1, -12, 1, 0)
    btnL.TextTruncate = Enum.TextTruncate.AtEnd  -- v5.9: nama panjang dipotong "...", gak meluber
    local function upd()
        if allKey and state[allKey] then btnL.Text = allLabel; btnL.TextColor3 = C.green
        else
            -- v5.9: tampilin NAMA item yg dipilih (urut alfabet), bukan cuma "N dipilih"
            local names = {}
            for nm in pairs(selSet) do names[#names+1] = nm end
            table.sort(names, function(a,b) return a:lower() < b:lower() end)
            if #names > 0 then
                btnL.Text = table.concat(names, ", ")
                btnL.TextColor3 = C.text
            else
                btnL.Text = "pilih..."
                btnL.TextColor3 = C.textDim
            end
        end
    end
    btn.MouseButton1Click:Connect(function()
        openTypePicker(labelTxt, listFn, selSet, allKey, upd, countFn)
    end)
    upd()
    return upd
end

