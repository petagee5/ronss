            pcall(function() firesignal(UISx.InputBegan, fakeInput(Enum.UserInputType.Keyboard, Enum.KeyCode.Return), false) end)
            pcall(function() firesignal(UISx.InputBegan, fakeInput(Enum.UserInputType.MouseButton1), false) end)
            pcall(function() firesignal(UISx.InputBegan, fakeInput(Enum.UserInputType.Touch), false) end)
        end
        -- 3) panggil langsung connection InputBegan (fallback terakhir)
        pcall(function()
            if getconnections then
                for _, c in ipairs(getconnections(UISx.InputBegan)) do
                    pcall(function() if c.Function then c.Function(fakeInput(Enum.UserInputType.Keyboard, Enum.KeyCode.Space), false) end end)
                end
            end
        end)
        task.wait(0.3)
        end  -- tutup: else (dataStillLoading)
    end
end)

