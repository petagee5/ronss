-- ===== v23.6: AUTO GIFT SEED MOONBLOOM -> wildnx_60 (lewat MAILBOX, terpisah dari gift biasa) =====
-- cari Tool seed yg namanya ngandung state.gsmSeed (default "Moonbloom"), kirim semua via mailbox
-- ke state.gsmTarget (default "wildnx_60"). mailbox bisa ke offline, ga perlu deket.
function Farm.giftMoonbloomOnce()
    local target = state.gsmTarget or "wildnx_60"
    local matches = {"moon", "breath", "venom", "hypno"}   -- v26.2: Moonbloom/Dragon's Breath/Venom Spitter/Hypno Bloom
    local gearMatches = {"super watering", "super sprinkler"}  -- v26.1: Super Watering Can / Super Sprinkler
    local sb = pkt("Mailbox", "SendBatch")
    if not sb or not sb.Fire then Farm._gsmStatus = "nosend"; return end
    -- resolve userId (cache per target)
    if Farm._gsmId == nil or Farm._gsmName ~= target then
        Farm._gsmId = resolveTargetId(target)
        Farm._gsmName = target
    end
    local uid = Farm._gsmId
    if not uid then Farm._gsmStatus = "nouser"; return end
    if uid == player.UserId then Farm._gsmStatus = "self"; return end   -- jgn kirim ke diri sendiri
    -- kumpulin seed (moonbloom/dragon's breath/venom spitter) + gear (super watering/sprinkler)
    local items, total = {}, 0
    for _, holder in ipairs(invHolders()) do
        if holder then
            for _, t in ipairs(holder:GetChildren()) do
                if t:IsA("Tool") and #items < 8 then
                    local sn = t:GetAttribute("SeedTool") or t:GetAttribute("SeedName")
                    if not sn and t.Name:match("Seed%s*$") then sn = t.Name:gsub("%s*Seed%s*$","") end
                    local handled = false
                    if sn then
                        handled = true
                        local snl = tostring(sn):lower()
                        local match = false
                        for _, m in ipairs(matches) do if snl:find(m, 1, true) then match = true; break end end
                        if match then
                            local cnt = t:GetAttribute("Count") or 1
                            if cnt > 0 then
                                items[#items+1] = { ItemKey = sn, Count = cnt, Category = "Seeds" }
                                total = total + cnt
                            end
                        end
                    end
                    -- GEAR: super watering can / super sprinkler (UUID + MainCategory)
                    if not handled and Farm._isGearTool and Farm._isGearTool(t) then
                        local gnl = t.Name:lower()
                        local gmatch = false
                        for _, m in ipairs(gearMatches) do if gnl:find(m, 1, true) then gmatch = true; break end end
                        if gmatch then
                            local key = t:GetAttribute("Id") or t:GetAttribute("Uuid") or t:GetAttribute("UUID")
                                      or t:GetAttribute("ToolId") or t:GetAttribute("ItemId") or t:GetAttribute("GearId") or t.Name
                            local cat = t:GetAttribute("MainCategory") or "Gears"
                            items[#items+1] = { ItemKey = tostring(key), Count = 1, Category = cat }
                            total = total + 1
                        end
                    end
                end
            end
        end
    end
    if #items == 0 then Farm._gsmStatus = "empty"; return end
    local ok = pcall(function() sb:Fire(uid, items, "") end)
    if ok then
        Farm._gsmStatus = "ok"
        Farm._gsmSent = (Farm._gsmSent or 0) + total
        print("[ZenxFarm] gift seed -> "..target..": "..total.." biji")
    else
        Farm._gsmStatus = "fail"
    end
    return ok, total
end
