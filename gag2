-- label -> posisi plot (prioritas dari tanaman dulu - posisi valid di area tanam)
function Farm.af2LabelToPos(label)
    local plotName = label:match(" %- (.+)$") or label:match("^(.+) %(kosong%)$") or label
    local gardens = workspace:FindFirstChild("Gardens")
    if not gardens then return nil end
    local plot = gardens:FindFirstChild(plotName)
    if not plot then return nil end
    local pos
    pcall(function()
        -- 1) posisi dari tanaman (paling valid, di area tanam)
        local plants = plot:FindFirstChild("Plants")
        if plants then
            for _, plant in ipairs(plants:GetChildren()) do
                if plant:IsA("Model") and plant.PrimaryPart then
                    pos = plant.PrimaryPart.Position; return
                end
                for _, p in ipairs(plant:GetDescendants()) do
                    if p:IsA("BasePart") and not p.Name:lower():find("fruit") then
                        pos = p.Position; return
                    end
                end
            end
        end
        -- 2) PlotSizeReference (tengah plot)
        if not pos then
            local ref = plot:FindFirstChild("PlotSizeReference")
            if ref and ref:IsA("BasePart") then pos = ref.Position; return end
        end
        -- 3) SpawnPoint (fallback terakhir)
        if not pos then
            local sp = plot:FindFirstChild("SpawnPoint")
            if sp and sp:IsA("BasePart") then pos = sp.Position end
        end
    end)
    return pos
end

