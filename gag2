-- "kapasitas max" - coba beberapa sumber dari data game. kalau gagal -> fallback.
Farm._invMaxCache = nil
local function getInvMax()
    local plr = Players.LocalPlayer
    if not plr then return state.sellMaxFallback end
    -- 1) attribute di player (nama-nama umum)
    for _, key in ipairs({"MaxInventory","InventoryLimit","BackpackLimit","MaxBackpack",
                          "InventorySize","MaxItems","ItemLimit","MaxSlots"}) do
        local v = plr:GetAttribute(key)
        if type(v) == "number" and v > 0 then return v end
    end
    -- 2) leaderstats / folder nilai (mis "Inventory" = "45/200")
    -- 3) scan PlayerGui cari teks pola "X/Y" yg Y-nya kelihatan kayak kapasitas
    local pg = plr:FindFirstChildOfClass("PlayerGui")
    if pg then
        for _, d in ipairs(pg:GetDescendants()) do
            if d:IsA("TextLabel") then
                local _, mx = tostring(d.Text):match("(%d+)%s*/%s*(%d+)")
                if mx then
                    local m = tonumber(mx)
                    -- kapasitas masuk akal: 10..5000 (buang angka acak kecil/besar)
                    if m and m >= 10 and m <= 5000 then return m end
                end
            end
        end
    end
    -- 4) fallback manual
    return state.sellMaxFallback
end
function Farm.sellOnce()
    Farm.updateBaseW()  -- v10.8: kalibrasi base weight dari buah di tas
