    if Farm._priceCache == nil then
        Farm._priceCache = {}
        pcall(function()
            local sd = RS:FindFirstChild("SharedModules") and RS.SharedModules:FindFirstChild("SeedData")
            if sd then
                local ok, data = pcall(require, sd)
                if ok and type(data) == "table" then
                    for k, v in pairs(data) do
                        if type(v) == "table" then
                            local val = v.SellValue or v.Value or v.BaseValue or v.Price or v.SellPrice
                            if type(val) == "number" then Farm._priceCache[k] = val end
                        end
                    end
                end
            end
        end)
    end
    -- prioritas: nilai asli SeedData > tabel harga seed > 1
    return Farm._priceCache[seedName] or CROP_PRICE[seedName] or 1
end

function Farm.collectOnce()
    local p = pkt("Garden", "CollectFruit")
    if not p or not p.Fire then print("[ZenxFarm] CollectFruit packet gak ada"); return end
    local gardens = workspace:FindFirstChild("Gardens")
    if not gardens then print("[ZenxFarm] Gardens gak ada"); return end

    local _t0 = tick()  -- v6.8: timing - ukur durasi 1 siklus collect
    local fired, skipped = 0, 0
    local typesFired = {}
    if state.collectWeightF ~= 0 then Farm.updateBaseW() end  -- v10.9: kalibrasi kalau filter berat aktif

    -- v10.6 FIX: kalau collectAll=false TAPI gak ada jenis yg dipilih, anggap SEMUA.
    -- (dulu bisa kejadian collectAll jadi false tapi selectedCollect kosong -> okType
    --  false buat semua -> collect DIAM TOTAL walau toggle nyala. ini jaring pengaman.)
    local effAll = state.collectAll
    if not effAll then
        local any = false
        for _ in pairs(state.selectedCollect) do any = true; break end
        if not any then effAll = true end  -- gak ada yg dipilih = ambil semua
    end

    -- proses 1 tanaman (fire buahnya). dipakai dua jalur di bawah.
    -- v9.4: jeda KONSISTEN tiap fire (~0.02s, niru pola sc temen yg gacor).
    -- tiap fire dikasih jeda kecil -> server gak nge-drop -> collect mulus & rapi.
    local function processPlant(plant, plantId, seedName)
        typesFired[seedName or "?"] = (typesFired[seedName or "?"] or 0) + 1
        local fruits = plant:FindFirstChild("Fruits")
        local fruitCount = 0
        if fruits and state.collectMulti then
            for _, fruit in ipairs(fruits:GetChildren()) do
                local fruitUUID = fruit:GetAttribute("FruitId") or fruit.Name:match("_([%x%-]+)$")
                local okMut = passMutation(fruit, state.selectedCollectMut, "collectMutAll", true)
                -- v22.6: toggle "Tanpa Mutasi" ON -> ikut ambil buah polos
                if not okMut and state.collectNoMut and getMutation(fruit) == nil then okMut = true end
                -- v34.7: mode KECUALI ON -> buah BERMUTASI dinilai ulang: SEMUA mutasi ke-collect
                -- KECUALI yg ada di daftar kecuali. buah polos tetep ikut aturan "Tanpa Mutasi".
                if state.collectMutExcept then
                    local m = getMutation(fruit)
                    if m ~= nil then okMut = not ((state.selectedCollectMutEx or {})[m]) end
                end
                local okW = passWeight(Farm.gardenKg(fruit, seedName), state.collectWeightF)  -- v10.9
                -- v23.1: anti-collect buah berat (>=100kg) - kalau ON, buah segede itu di-skip
                local okHeavy = true
                if state.antiCollectHeavy then
                    local kg = Farm.gardenKg(fruit, seedName)
                    if kg and kg >= (state.antiCollectHeavyKg or 100) then okHeavy = false end
                end
                -- v15.4: skip buah BASI (decay > batas) kalau collectFreshOnly ON.
                local okFresh = true
                if state.collectFreshOnly then
                    local dec = fruit:GetAttribute("DecayAlpha")
                    if type(dec) == "number" and dec > (state.collectFreshMax or 0.5) then okFresh = false end
                end
                -- v34.9: GOLD kg berapapun - mutasi Gold nembus filter mutasi + kg + anti-heavy
                -- (aturan Fresh Only tetep berlaku). aktif cuma pas siklus Collect 2 dgn toggle ON.
                if state.collectGoldAnyKg and getMutation(fruit) == "Gold" then
                    okMut = true; okW = true; okHeavy = true
                end
                if fruitUUID and #tostring(fruitUUID) >= 30 and okMut and okW and okFresh and okHeavy then
                    pcall(function() p:Fire(tostring(plantId), tostring(fruitUUID)) end)
                    Farm._collectKg = Farm._collectKg + Farm.gardenKg(fruit, seedName)  -- v10.8
                    fired = fired + 1; fruitCount = fruitCount + 1
                    task.wait()  -- jeda konsisten tiap fire (pola temen yg gacor)
                end
            end
        end
        if fruitCount == 0 and state.collectSingle then
            if plant:GetAttribute("PlantGrowthReady") == true then
                local pid = tostring(plantId)
                pcall(function() p:Fire(pid, pid) end)
                pcall(function() p:Fire(pid, "") end)
                fired = fired + 1
                task.wait()  -- jeda konsisten tiap fire
            end
        end
    end

    if state.collectMostFirst then
        -- v9.7: mode FOKUS anti-kejar-regrowth.
        -- collect 1 jenis (terbanyak) SEKALI LEWAT, lalu LEPAS (tandai _focusDone) ->
        -- pindah ke jenis terbanyak berikutnya. JANGAN balik ngejar buah yg numpuk lagi
        -- (dulu strawberry 400 turun 390 tumbuh 420 -> stuck terus -> lemot & jenis lain
        -- gak kebagian). stlh SEMUA jenis kebagian 1x / stlh sell -> ronde baru.
        Farm._focusDone = Farm._focusDone or {}
        local byType = {}
        for _, plot in ipairs(gardens:GetChildren()) do
            local plants = plot:FindFirstChild("Plants")
            if plants then
                for _, plant in ipairs(plants:GetChildren()) do
                    local plantId = plant:GetAttribute("PlantId")
                    local seedName = plant:GetAttribute("SeedName")
                    local okType = effAll or (seedName ~= nil and state.selectedCollect[seedName] == true)
                    if plantId and not okType then skipped = skipped + 1 end
                    if plantId and okType then
                        local e = byType[seedName or "?"]
                        if not e then e = { list = {}, fruits = 0 }; byType[seedName or "?"] = e end
                        e.list[#e.list+1] = { plant, plantId, seedName }
                        -- v10.4 FIX: hitung cuma buah yg BISA dikoleksi sesuai toggle.
                        -- dulu (v10.3) single-ready selalu dihitung -> kalau Single Harvest
                        -- OFF, fokus nyangkut di jenis single (gak kekoleksi) -> buah multi
                        -- gak kebagian giliran. sekarang ngitung niru processPlant:
                        --   multi (folder Fruits) cuma kalau Multi Harvest ON
                        --   single-ready cuma kalau Single Harvest ON
                        local fr = plant:FindFirstChild("Fruits")
                        local nf = fr and #fr:GetChildren() or 0
                        if nf > 0 and state.collectMulti then
                            e.fruits = e.fruits + nf
                        elseif nf == 0 and state.collectSingle and plant:GetAttribute("PlantGrowthReady") == true then
                            e.fruits = e.fruits + 1
                        end
                    end
                end
            end
        end
        -- pilih jenis terbanyak yg BELUM kebagian ronde ini (_focusDone)
        local focus, bestN
        for sn, e in pairs(byType) do
            if e.fruits > 0 and not Farm._focusDone[sn] and (not bestN or e.fruits > bestN) then
                bestN = e.fruits; focus = sn
            end
        end
        -- semua jenis udah kebagian / gak ada yg punya buah -> mulai ronde baru
        if not focus then
            Farm._focusDone = {}
            for sn, e in pairs(byType) do
                if e.fruits > 0 and (not bestN or e.fruits > bestN) then bestN = e.fruits; focus = sn end
            end
        end
        -- collect jenis fokus SEKALI LEWAT, lalu tandai selesai (lepas, gak ngejar regrowth)
        if focus and byType[focus] then
            dprint("[ZenxFarm] collect fokus: "..focus.." ("..byType[focus].fruits.." buah)")
            for _, t in ipairs(byType[focus].list) do
                if not state.autoCollect then break end
                processPlant(t[1], t[2], t[3])
            end
            Farm._focusDone[focus] = true
        end
    elseif not state.collectExpensiveFirst then
        -- v7.8: JALUR CEPAT (default) - fire langsung tanpa bangun tabel.
        -- ini balikin performa: gak ada alokasi tabel tiap siklus -> gak bikin lemot.
        for _, plot in ipairs(gardens:GetChildren()) do
            local plants = plot:FindFirstChild("Plants")
            if plants then
                for _, plant in ipairs(plants:GetChildren()) do
                    local plantId = plant:GetAttribute("PlantId")
                    local seedName = plant:GetAttribute("SeedName")
                    local okType = effAll or (seedName ~= nil and state.selectedCollect[seedName] == true)
                    if plantId and not okType then skipped = skipped + 1 end
                    if plantId and okType then processPlant(plant, plantId, seedName) end
                end
            end
        end
    else
        -- JALUR TERMAHAL DULU - bangun tabel + sort (cuma pas fitur ON, jadi
        -- beban sort cuma dibayar kalau kamu emang mau prioritas mahal).
        local todo = {}
        for _, plot in ipairs(gardens:GetChildren()) do
            local plants = plot:FindFirstChild("Plants")
            if plants then
                for _, plant in ipairs(plants:GetChildren()) do
                    local plantId = plant:GetAttribute("PlantId")
                    local seedName = plant:GetAttribute("SeedName")
                    local okType = effAll or (seedName ~= nil and state.selectedCollect[seedName] == true)
                    if plantId and not okType then skipped = skipped + 1 end
                    if plantId and okType then
                        todo[#todo+1] = { plant, plantId, seedName, Farm.cropValue(seedName) }
                    end
                end
            end
        end
        table.sort(todo, function(a, b) return a[4] > b[4] end)  -- termahal dulu
        for _, e in ipairs(todo) do processPlant(e[1], e[2], e[3]) end
    end
    if fired > 0 then
        local tlist = {}
        for nm, c in pairs(typesFired) do tlist[#tlist+1] = nm.."("..c..")" end
        -- v6.8: tambah DURASI siklus - biar ketahuan collect makan waktu berapa detik
        local _dur = tick() - _t0
        dprint(string.format("[ZenxFarm] collect fired=%d skipped=%d durasi=%.2fs | jenis: %s",
            fired, skipped, _dur, (#tlist>0 and table.concat(tlist,", ") or "-")))
    end
end

