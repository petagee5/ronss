-- ===== COLLECT: Garden.CollectFruit:Fire(PlantId, FruitUUID) =====
-- struktur: Workspace.Gardens.PlotN.Plants.<pid>_<PlantUUID>
--             .Fruits.<pid>_<PlantUUID>_<FruitUUID>
-- arg1 = PlantId (attr .PlantId di plant), arg2 = FruitUUID (UUID terakhir di nama fruit)
-- v5.9: deteksi mutasi sebuah fruit/objek. game biasanya simpen mutasi di attribute
-- (nama belum pasti) atau di nama objek. coba beberapa kemungkinan attribute umum.
-- return: nama mutasi (string) atau nil kalau gak ada / gak kedeteksi.
local MUT_ATTR_KEYS = {"Mutation","Mutations","Variant","Variants","Type","Modifier"}
local function getMutation(obj)
    for _, k in ipairs(MUT_ATTR_KEYS) do
        local v = obj:GetAttribute(k)
        if type(v) == "string" and v ~= "" and v:lower() ~= "none" and v:lower() ~= "normal" then
            return v
        end
    end
    return nil
end
-- cek apakah objek lolos filter mutasi. allKey true -> lolos semua.
local function passMutation(obj, selSet, allKey, mutOnly)
    if state[allKey] then
        -- v22.5: kalau mutOnly -> "Semua mutasi" = cuma yg BERMUTASI (buah polos di-skip)
        if mutOnly then return getMutation(obj) ~= nil end
        return true
    end
    -- ada minimal 1 mutasi terpilih cocok
    local m = getMutation(obj)
    if not m then return false end  -- filter mutasi aktif tapi objek gak punya mutasi -> skip
    -- m bisa multi (mis "Gold,Wet"). cek tiap bagian.
    for part in tostring(m):gmatch("[^,%s]+") do
        if selSet[part] then return true end
    end
    return false
end

-- v10.9: filter berat. f=0 -> lolos semua. f>0 -> cuma kg DI ATAS f. f<0 -> cuma DI BAWAH |f|.
local function passWeight(kg, f)
    if not f or f == 0 then return true end       -- filter off -> semua lolos
    if kg == nil then return false end             -- v13.3: kg gak ketauan + filter aktif -> JANGAN proses (aman)
    if f > 0 then return kg >= f end               -- +N = di atas N
    return kg <= -f                                -- -N = di bawah N
end

