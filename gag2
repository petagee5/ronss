function Farm.shovelOnce()
    -- v9.8: format ASLI: Shovel.UseShovel(plantId, "", "Shovel", tool)
    -- FIX dari debug: game nolak "You can't remove your only carrot!" = gak boleh gali
    -- tanaman TERAKHIR dari suatu jenis. dulu sc nyangkut spam UUID yg sama (ditolak terus).
    -- solusi: SISAIN min 1 per jenis + jangan gali tanaman terakhir tiap jenis.
    local p = pkt("Shovel", "UseShovel")
    if not p or not p.Fire then print("[ZenxFarm] shovel: remote Shovel.UseShovel gak ada"); return end
    local gardens = workspace:FindFirstChild("Gardens")
    if not gardens then return end
    local char = player.Character
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    local shovelTool
    for _, h in ipairs({ char, player:FindFirstChildOfClass("Backpack") }) do
        if h then for _, t in ipairs(h:GetChildren()) do
            if t:IsA("Tool") and t.Name:lower():find("shovel") then shovelTool = t; break end
        end end
        if shovelTool then break end
    end
    if not shovelTool then dprint("[ZenxFarm] shovel: tool Shovel gak ada di backpack"); return end
    if shovelTool.Parent ~= char and hum then pcall(function() hum:EquipTool(shovelTool) end); task.wait(0.1) end

    local MY = player.UserId
    -- HITUNG dulu jumlah tanaman KITA per jenis (buat aturan "sisain 1 per jenis")
    local typeCount = {}
    for _, plot in ipairs(gardens:GetChildren()) do
        local plants = plot:FindFirstChild("Plants")
        if plants then
            for _, plant in ipairs(plants:GetChildren()) do
                local ownerId = tonumber(plant.Name:match("^(%d+)_"))
                if (not ownerId or ownerId == MY) then
                    local sn = plant:GetAttribute("SeedName") or "?"
                    typeCount[sn] = (typeCount[sn] or 0) + 1
                end
            end
        end
    end

    local removed = 0
    local galiPerType = {}  -- berapa udah digali per jenis (biar sisain 1)
    for _, plot in ipairs(gardens:GetChildren()) do
        local plants = plot:FindFirstChild("Plants")
        if plants then
            for _, plant in ipairs(plants:GetChildren()) do
                if not state.autoShovel then break end
                local ownerId = tonumber(plant.Name:match("^(%d+)_"))
                local plantId = plant.Name
                local seedName = plant:GetAttribute("SeedName") or "?"
                local okType = state.shovelAll or (state.selectedShovel[seedName] == true)
                -- SISAIN 1 per jenis: kalau gali tanaman ini bakal nyisain < 1, SKIP
                -- (total jenis - udah digali - 1 ini >= 1)  => boleh kalau masih > 1 tersisa
                local sisa = (typeCount[seedName] or 0) - (galiPerType[seedName] or 0)
                local bolehGali = sisa > 1  -- harus nyisain minimal 1
                if (not ownerId or ownerId == MY) and okType and #plantId >= 30 and bolehGali then
                    pcall(function() p:Fire(plantId, "", shovelTool.Name, shovelTool) end)
                    removed = removed + 1
                    galiPerType[seedName] = (galiPerType[seedName] or 0) + 1
                    if removed % 30 == 0 then task.wait() end
                end
            end
        end
    end
    if removed > 0 then dprint("[ZenxFarm] shovel: "..removed.." tanaman digali (sisain 1/jenis)") end
end

