        local function refresh()
            for _, c in ipairs(sc:GetChildren()) do
                if c:IsA("Frame") or c:IsA("TextLabel") then c:Destroy() end
            end
            ord = 0
            if #Farm._gfHistory == 0 then
                local e = newRow(24); cell(e, "belum ada history gift.", 0, 1, C.textMute)
