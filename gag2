            for _, t in ipairs(holder:GetChildren()) do
                local fid = t:GetAttribute("Id")
                local fj = t:GetAttribute("Fruit") or t:GetAttribute("FruitName")
                if fid and fj then counts[fj] = (counts[fj] or 0) + 1 end
