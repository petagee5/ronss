-- nunggu notif "Trade completed" BARU (yg ga ada di ignoreSet). return true kalau kedeteksi sblm timeout.
function Farm.waitTradeDone(timeout, ignoreSet)
    ignoreSet = ignoreSet or {}
    timeout = timeout or 20
    local roots = _guiRoots()
    if #roots == 0 then return false end
    local t0 = os.clock()
    while (os.clock() - t0) < timeout do
        local hit = false
        for _, root in ipairs(roots) do
            pcall(function()
                for _, d in ipairs(root:GetDescendants()) do
                    if (d:IsA("TextLabel") or d:IsA("TextButton")) and not ignoreSet[d]
                       and type(d.Text) == "string" and d.Text:lower():find("trade complete", 1, true) then
                        hit = true; break
                    end
                end
            end)
            if hit then break end
        end
        if hit then return true end
        task.wait(0.25)
    end
    return false
end
