    local function calcInvTotal()
        local n, val = 0, 0
        for _, holder in ipairs(invHolders()) do
            if holder then
                for _, t in ipairs(holder:GetChildren()) do
                    local fj = t:GetAttribute("Fruit") or t:GetAttribute("FruitName")
                    local fid = t:GetAttribute("Id")
                    if fj and fid then
                        n = n + 1
                        val = val + (Farm.fruitPrice(t) or 0)   -- sama kayak KALKULASI (harga pasar)
                    end
                end
            end
        end
        return n, val
    end

    -- bener2 keliatan? (diri + semua ancestor Visible, ScreenGui Enabled)
    local function isShown(g)
        local node = g
        while node and node:IsA("GuiObject") do
            if not node.Visible then return false end
            node = node.Parent
        end
        if node and node:IsA("ScreenGui") then return node.Enabled end
        return true
    end

    -- window inventory = frame GEDE & keliatan di BackpackGui yg punya sel (ToolName). hotbar ke-skip krn kecil.
    local function findInvWindow()
        local pg = player:FindFirstChild("PlayerGui")
        local bgui = pg and pg:FindFirstChild("BackpackGui")
        if not bgui then return nil end
        local best
        for _, d in ipairs(bgui:GetDescendants()) do
            if d:IsA("GuiObject") and d.Visible
               and d.AbsoluteSize.X > 300 and d.AbsoluteSize.Y > 200
               and d:FindFirstChild("ToolName", true) and isShown(d) then
                local area = d.AbsoluteSize.X * d.AbsoluteSize.Y
                if not best or area > (best.AbsoluteSize.X * best.AbsoluteSize.Y) then best = d end
            end
        end
        return best
    end

