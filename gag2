-- ===== AUTO GRAB SEED JATUH (event) - v6.1: NGEBUT (biar gak kalah sama orang) =====
-- prioritas KECEPATAN: fire touch DULUAN tanpa nunggu/pindah (firetouchinterest sering
-- udah cukup walau gak nempel). baru kalau seed masih ada di scan berikutnya, geser
-- karakter ke titik jatuhnya. buang task.wait per-seed (dulu 0.05s/seed = lambat).

-- v6.4: grab 1 seed secepat mungkin (touch + opsional geser ke titik jatuh).
-- dipakai bareng oleh listener event (instan pas spawn) DAN polling (jaring pengaman).
local function grabOneSeed(o)
    local char = player.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not (root and firetouchinterest and o and o:IsA("BasePart")) then return end
    -- 1) fire touch LANGSUNG (tanpa pindah) - paling cepat
    pcall(function()
        firetouchinterest(root, o, 0)
        firetouchinterest(root, o, 1)
    end)
    -- 2) kalau masih ada & posisinya valid, geser ke titik jatuh lalu touch lagi
    if o.Parent and o:IsDescendantOf(workspace) then
        local sp = o.Position
        if sp.Magnitude > 1 and (sp - root.Position).Magnitude < 150 then
            pcall(function() root.CFrame = CFrame.new(sp.X, root.Position.Y, sp.Z) end)
            pcall(function()
                firetouchinterest(root, o, 0)
                firetouchinterest(root, o, 1)
            end)
        end
    end
end

-- v6.4: LISTENER INSTAN - grab seed DETIK ITU JUGA pas muncul (sebelum sempat jatuh).
-- ini yg bikin sc lain selalu duluan: mereka pakai event, bukan nunggu polling.
do
    local function hookFolder(folder)
        if not folder then return end
        folder.DescendantAdded:Connect(function(o)
            if not (isCurrentGen() and state.autoGrabSeed) then return end
            if o:IsA("BasePart") then
                grabOneSeed(o)  -- instan, gak nunggu loop
            end
        end)
    end
    task.spawn(function()
        -- folder bisa belum ada pas script jalan -> tungguin
        for _ = 1, 60 do
            local map = workspace:FindFirstChild("Map")
            local folder = map and map:FindFirstChild("SeedPackSpawnClient")
            if folder then hookFolder(folder); break end
            task.wait(1)
        end
    end)
end

function Farm.grabSeedOnce()
    local map = workspace:FindFirstChild("Map")
    local folder = map and map:FindFirstChild("SeedPackSpawnClient")
    if not folder then return end
    local char = player.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return end

    -- v7.9: PASS 0 - ClickPack("1") (metode sc cepat: fire remote langsung,
    -- gak perlu touch/teleport). aman: kalau gak ada seed, gak ngefek apa2.
    -- ini metode utama; touch di bawah jadi cadangan kalau ClickPack gak cukup.
    local hasSeed = false
    for _, o in ipairs(folder:GetDescendants()) do
        if o:IsA("BasePart") and o.Name == "Part" and o.Anchored then hasSeed = true; break end
    end
    if hasSeed then
        local cp = pkt("SeedPack", "ClickPack")
        if cp and cp.Fire then
            for _ = 1, 5 do pcall(function() cp:Fire("1") end) end
        end
    end

    if not firetouchinterest then return end

    -- PASS 1: fire touch SEMUA seed langsung (tanpa pindah, tanpa delay) - secepat mungkin
    local pending = {}
    for _, o in ipairs(folder:GetDescendants()) do
        if o:IsA("BasePart") then
            local tries = o:GetAttribute("_zgrabN") or 0
            if tries < 3 then  -- coba grab tiap seed maks 3x
                pcall(function()
                    firetouchinterest(root, o, 0)
                    firetouchinterest(root, o, 1)
                end)
                o:SetAttribute("_zgrabN", tries + 1)
                pending[#pending+1] = o
            end
        end
    end

    -- PASS 2: buat seed yg masih ada (touch gak cukup) -> geser karakter ke titik jatuh,
    -- lalu touch lagi. cuma 1x geser ke seed terdekat biar gak loncat-loncat.
    if #pending > 0 then
        -- pilih seed terdekat ke karakter
        local nearest, bestD
        for _, o in ipairs(pending) do
            -- v6.2: validasi KETAT - cegah teleport ke titik aneh kalau seed keburu
            -- keambil orang (part ke-destroy / posisi ke-reset ke 0,0,0 sebelum hilang).
            if o.Parent and o:IsDescendantOf(workspace) then
                local sp = o.Position
                -- buang posisi sampah: (0,0,0) atau dekat origin = seed udah invalid
                if sp.Magnitude > 1 then
                    local d = (sp - root.Position).Magnitude
                    -- cuma kalau jaraknya masuk akal (<150 stud). seed event jatuh di
                    -- sekitar map, gak mungkin ratusan ribu stud - itu tanda posisi ngaco.
                    if d < 150 and (not bestD or d < bestD) then
                        bestD, nearest = d, o
                    end
                end
            end
        end
        if nearest and nearest.Parent and nearest:IsDescendantOf(workspace) then
            local sp = nearest.Position
            -- cek SEKALI LAGI tepat sebelum teleport (seed bisa hilang di frame ini)
            if sp.Magnitude > 1 and (sp - root.Position).Magnitude < 150 then
                pcall(function() root.CFrame = CFrame.new(sp.X, root.Position.Y, sp.Z) end)
                pcall(function()
                    firetouchinterest(root, nearest, 0)
                    firetouchinterest(root, nearest, 1)
                end)
            end
        end
    end
end
