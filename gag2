-- farm: baca daftar akun yg penuh (cache 8s biar gak spam request)
function Farm.getFullRegistry()
    local now = os.clock()
    if Farm._fullCache and (now - (Farm._fullCacheAt or 0)) < 8 then return Farm._fullCache end
    local set = {}
    local url = Farm.fullRegistryUrl()
    if url then
        local resp = Farm.relayReq({ Url = url, Method = "GET" })
        local body = resp and (resp.Body or resp.body)
        if body then
            local ok, d = pcall(function() return HS:JSONDecode(body) end)
            if ok and type(d) == "table" then
