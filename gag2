-- ===== ANTI-BOT: deteksi player auto-sell (Sheckles berubah >=5x dalam 2s) -> hop =====
-- pantau Sheckles cepat (0.2s). hitung perubahan per window 2 detik.
-- bot = >=5 perubahan/2s (sell beberapa item beruntun). player normal: sell 1-1 (jarang).
-- hop kalau 2 window berturut kedeteksi (biar gak false-positive).
do
    local lastSheck = {}    -- userId -> nilai Sheckles terakhir
    local changes = {}      -- userId -> jumlah perubahan di window berjalan
    local hitStreak = {}    -- userId -> berapa window berturut yg >=5 perubahan
    local MY_ID = player.UserId
    local WINDOW = 2          -- detik per window
    local TICK = 0.2          -- cek tiap 0.2s
    local THRESHOLD = 5       -- >=5 perubahan dalam window = mencurigakan
    local NEED_WINDOWS = 2    -- 2 window berturut baru hop

    -- loop hitung perubahan (cepat)
    task.spawn(function()
        while isCurrentGen() do
            task.wait(TICK)
            if isCurrentGen() and state.antiBot then
                for _, p in ipairs(Players:GetPlayers()) do
                    if p.UserId ~= MY_ID then
                        local ls = p:FindFirstChild("leaderstats")
                        local sv = ls and ls:FindFirstChild("Sheckles")
                        if sv then
                            local now = sv.Value
                            local prev = lastSheck[p.UserId]
                            if prev ~= nil and now ~= prev then
                                changes[p.UserId] = (changes[p.UserId] or 0) + 1
                            end
                            lastSheck[p.UserId] = now
                        end
                    end
                end
            else
                if next(changes) then changes={}; lastSheck={}; hitStreak={} end
            end
        end
    end)
    -- loop evaluasi window (tiap 2 detik)
    task.spawn(function()
        while isCurrentGen() do
            task.wait(WINDOW)
            if isCurrentGen() and state.antiBot then
                for uid, cnt in pairs(changes) do
                    if cnt >= THRESHOLD then
                        hitStreak[uid] = (hitStreak[uid] or 0) + 1
                    else
                        hitStreak[uid] = 0
                    end
                    if (hitStreak[uid] or 0) >= NEED_WINDOWS then
                        local nm = uid
                        local pp = Players:GetPlayerByUserId(uid)
                        if pp then nm = pp.Name end
                        print("[ZenxFarm] BOT terdeteksi: "..nm.." (Sheckles berubah "..cnt.."x/2s, 2 window) -> HOP")
                        -- v5.5: hop dulu; cuma matiin Anti-Bot kalau hop BERHASIL.
                        -- kalau hop gagal (gak nemu server lain), biarin Anti-Bot tetap ON
                        -- biar nyoba lagi nanti - daripada mati percuma tanpa pindah.
                        task.spawn(function()
                            local ok = doHop()
                            if ok then state.antiBot = false end
                        end)
                        break
                    end
                end
                changes = {}  -- reset window
            end
        end
    end)
end

