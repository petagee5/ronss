function Farm.saveMktCache(cycle, map)
    if type(writefile) ~= "function" then return end
    pcall(function() writefile(MKT_FILE, HS:JSONEncode({ cycle = cycle, map = map })) end)
end
function Farm.loadMktCache(cycle)
    if type(readfile) ~= "function" or type(isfile) ~= "function" or not isfile(MKT_FILE) then return nil end
    local ok, d = pcall(function() return HS:JSONDecode(readfile(MKT_FILE)) end)
    if ok and type(d) == "table" and type(d.map) == "table" then
        if not cycle or d.cycle == cycle then return d.map end  -- cuma valid kalau siklus restock sama
    end
    return nil
