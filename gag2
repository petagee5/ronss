-- Big=2x, Mega=4x nge-scale seluruh model jadi RootPart ikut gede. baseline = root terkecil per jenis.
Farm._petBase = Farm._petBase or {}
function Farm.petSizeTier(uuid, petName)
    if not petName then return "Normal", 1 end
    local map = workspace:FindFirstChild("Map")
    local spawns = map and map:FindFirstChild("WildPetSpawns")
    if not spawns then return "Normal", 1 end
    local model
    for _, m in ipairs(spawns:GetChildren()) do
        if m.Name:find(uuid, 1, true) then model = m; break end
    end
    if not model then return "Normal", 1 end
    -- patokan utama: RootPart.Size (stabil). fallback: bounding box.
    local lin
    local rp = model:FindFirstChild("RootPart", true)
    if rp and rp:IsA("BasePart") then
        lin = math.max(rp.Size.X, rp.Size.Y, rp.Size.Z)
    else
        local sz
        pcall(function()
            if model:IsA("Model") then local _, s = model:GetBoundingBox(); sz = s
            elseif model:IsA("BasePart") then sz = model.Size end
        end)
        if sz then lin = math.max(sz.X, sz.Y, sz.Z) end
    end
    if not lin or lin <= 0 then return "Normal", 1 end
    local base = Farm._petBase[petName]
    if not base or lin < base then Farm._petBase[petName] = lin; base = lin end
    local scale = lin / base
    if scale >= 2.8 then return "Mega", scale
    elseif scale >= 1.4 then return "Big", scale
    else return "Normal", scale end
end
