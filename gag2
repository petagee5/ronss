-- v36.5: LOOP auto drop. jalan sampai state.dropAuto=false atau target tercapai.
-- tiap cycle: cari buah in-range -> equip (WAJIB dipegang) -> RequestDrop -> unequip.
-- ga ada buah cocok -> nunggu (cycle ga mati). counter dropDone nyampe target -> auto OFF.
function Farm.startDropLoop()
    task.spawn(function()
        local p = pkt("DroppedItem", "RequestDrop")
        if not (p and p.Fire) then print("[ZenxFarm] RequestDrop packet gak ada"); state.dropAuto=false; return end
        print("[ZenxFarm] DROP FRUIT auto: ON (target "..tostring(state.dropTarget)..")")
        while state.dropAuto do
            -- target tercapai -> mati sendiri
            if (state.dropDone or 0) >= (state.dropTarget or 0) then
                print("[ZenxFarm] DROP FRUIT: target "..tostring(state.dropTarget).." tercapai -> OFF")
                state.dropAuto = false
                pcall(function() if Farm._syncDropToggle then Farm._syncDropToggle() end end)
                break
            end
            local minVal = (tonumber(state.dropMinM) or 0) * 1e6
            local maxVal = (tonumber(state.dropMaxM) or 999999) * 1e6
            local char = player.Character
            local hum = char and char:FindFirstChildOfClass("Humanoid")

            -- v38.2: kumpulin SEMUA buah in-range dulu (Tool + non-Tool).
            local tools, configs = {}, {}   -- tools=udah Tool siap drop; configs={id} perlu promote
            for _, holder in ipairs(getFruitHolders()) do
                for _, o in ipairs(holder:GetChildren()) do
                    local id = o:GetAttribute("Id")
                    local fj = o:GetAttribute("Fruit") or o:GetAttribute("FruitName")
                    if id and fj then
                        local pr = Farm.fruitPrice(o) or 0
                        if pr >= minVal and pr <= maxVal then
                            if o:IsA("Tool") then tools[#tools+1] = {obj=o, id=id}
                            else configs[#configs+1] = tostring(id) end
                        end
                    end
                end
            end

            if #tools == 0 and #configs == 0 then
                task.wait(1)   -- ga ada buah cocok
            else
                -- 1) PROMOTE semua buah inventory sekaligus (beruntun, ga nunggu satu2)
                if #configs > 0 then
                    local pp = pkt("Backpack", "PromoteFruit")
                    if pp and pp.Fire then
                        for _, uuid in ipairs(configs) do
                            if not state.dropAuto then break end
                            pcall(function() pp:Fire(uuid) end)
                            task.wait()   -- 1 frame antar promote
                        end
                        -- kasih waktu server proses promote batch (buah jadi Tool)
                        task.wait(0.3)
                        -- kumpulin ulang Tool yg baru muncul dari promote
                        for _, holder in ipairs(getFruitHolders()) do
                            for _, o in ipairs(holder:GetChildren()) do
                                if o:IsA("Tool") then
                                    local id = o:GetAttribute("Id")
                                    local fj = o:GetAttribute("Fruit") or o:GetAttribute("FruitName")
                                    if id and fj then
                                        local pr = Farm.fruitPrice(o) or 0
                                        if pr >= minVal and pr <= maxVal then
                                            -- cek belum ada di tools
                                            local dup = false
                                            for _, e in ipairs(tools) do if e.obj == o then dup = true break end end
                                            if not dup then tools[#tools+1] = {obj=o, id=id} end
                                        end
                                    end
                                end
                            end
                        end
                    end
                end

                -- 2) DROP semua Tool beruntun. v38.3: counter naik CUMA kalau buah beneran
                -- ilang (ke-drop), bukan pas fire. dulu bug: fire = +1 padahal buah masih dipegang.
                for _, e in ipairs(tools) do
                    if not state.dropAuto then break end
                    if (state.dropDone or 0) >= (state.dropTarget or 0) then break end
                    if hum and e.obj:IsA("Tool") then
                        pcall(function() hum:EquipTool(e.obj) end)
                    end
                    pcall(function() p:Fire("HarvestedFruits", tostring(e.id)) end)
                    -- verifikasi: tunggu buah beneran ilang dari tas (parent nil = ke-drop).
                    -- poll per-frame, timeout pendek. cuma hitung kalau beneran ilang.
                    local t0 = os.clock()
                    local gone = false
                    repeat
                        task.wait()
                        if e.obj.Parent == nil then gone = true break end
                    until (os.clock() - t0) > 0.4
                    if gone then
                        state.dropDone = (state.dropDone or 0) + 1
                        pcall(function() if Farm._syncDropToggle then Farm._syncDropToggle() end end)
                    end
                end
                task.wait(0.1)   -- jeda kecil sebelum scan batch berikutnya
            end
        end
        -- pastikan tool dilepas pas berhenti
        local hum = player.Character and player.Character:FindFirstChildOfClass("Humanoid")
        if hum then pcall(function() hum:UnequipTools() end) end
        print("[ZenxFarm] DROP FRUIT auto: OFF (total drop sesi: "..tostring(state.dropDone)..")")
    end)
end

-- ===== v37.1: AUTO COLLECT buah yg di-drop di tanah (Workspace.DroppedItems) =====
-- tiap buah = Model "DroppedItem_<uuid>" + ProximityPrompt (PickupPrompt).
-- collect = fireproximityprompt(prompt) (KEBUKTI works). filter value opsional.
-- value dihitung dari FruitData JSON (SizeMultiplier) + ObjectText (nama+mutasi).

-- hitung value 1 buah tanah dari attribute-nya. return angka atau nil.
function Farm.groundFruitValue(model)
    local okName, objText = pcall(function()
        for _, pp in ipairs(model:GetDescendants()) do
            if pp:IsA("ProximityPrompt") then return pp.ObjectText end
        end
    end)
    -- ObjectText contoh: "Dragon's Breath [Bloodlit] [32.93kg]"
    local jenis, mut
    if okName and type(objText) == "string" then
        jenis = objText:match("^([^%[]+)")            -- teks sebelum '['
        if jenis then jenis = jenis:gsub("%s+$", "") end
        mut = objText:match("%[([%a%s]+)%]")           -- kurung pertama = mutasi (huruf)
        if mut then mut = mut:gsub("%s+$", "") end
    end
    -- SizeMultiplier dari FruitData JSON
    local sm
    local fd = model:GetAttribute("FruitData")
    if type(fd) == "string" then
        local ok, dec = pcall(function() return game:GetService("HttpService"):JSONDecode(fd) end)
        if ok and type(dec) == "table" then
            sm = dec.SizeMultiplier or dec.Size or dec.Weight
        end
    end
    if not sm then sm = model:GetAttribute("SizeMultiplier") end
    if not jenis or type(sm) ~= "number" then return nil end
    -- bikin objek dummy ber-attribute biar bisa pakai Farm.fruitPrice
    local dummy = Instance.new("Part")
    dummy:SetAttribute("Fruit", jenis)
    dummy:SetAttribute("SizeMultiplier", sm)
    if mut and mut ~= "None" then dummy:SetAttribute("Mutation", mut) end
    local val = Farm.fruitPrice(dummy)
    dummy:Destroy()
    return val, jenis, sm, mut
end

-- collect 1 buah (fire prompt). return true kalau di-fire.
function Farm.collectGroundFruit(model)
    for _, pp in ipairs(model:GetDescendants()) do
        if pp:IsA("ProximityPrompt") then
            pcall(function() fireproximityprompt(pp) end)
            return true
        end
    end
    return false
end

-- LOOP auto collect. jalan sampai state.collectAuto=false.
-- tiap cycle: scan DroppedItems -> filter value in-range -> fire prompt.
function Farm.startCollectLoop()
    task.spawn(function()
        if type(fireproximityprompt) ~= "function" then
            print("[ZenxFarm] executor gak punya fireproximityprompt - auto collect ga bisa")
            state.collectAuto = false
            pcall(function() if Farm._syncCollectToggle then Farm._syncCollectToggle() end end)
            return
        end
        print("[ZenxFarm] AUTO COLLECT: ON")
        while state.collectAuto do
            local di = workspace:FindFirstChild("DroppedItems")
            if di then
                local minVal = (tonumber(state.collectMinM) or 0) * 1e6
                local maxVal = (tonumber(state.collectMaxM) or 999999) * 1e6
                for _, model in ipairs(di:GetChildren()) do
                    if not state.collectAuto then break end
                    if model:IsA("Model") and model.Name:find("DroppedItem") then
                        local ok = true
                        -- filter value kalau diaktifin
                        if state.collectFilter then
                            local val = Farm.groundFruitValue(model)
                            ok = val and val >= minVal and val <= maxVal
                        end
                        if ok then
                            -- v37.6: TP ke buah kalau JAUH (prompt butuh deket). deket = skip TP.
                            local char = player.Character
                            local hrp = char and char:FindFirstChild("HumanoidRootPart")
                            local target
                            pcall(function()
                                local pp = model:FindFirstChildWhichIsA("ProximityPrompt", true)
                                if pp and pp.Parent and pp.Parent:IsA("BasePart") then target = pp.Parent
                                else target = model:FindFirstChildWhichIsA("BasePart", true) end
                            end)
                            if hrp and target then
                                local dist = (hrp.Position - target.Position).Magnitude
                                if dist > 15 then
                                    -- TP deket buah (2 stud di atas + samping dikit biar ga nabrak)
