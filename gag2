function Farm.giftFruitOnce()
    local sb = pkt("Mailbox", "SendBatch")
    if not sb or not sb.Fire then Farm._gfStatus = "nosend"; print("[ZenxFarm] SendBatch gak ada"); return end

    local target = state.gfTarget
    local useRelay = state.gfSheckMode and state.gfRelayUrl and state.gfRelayUrl ~= ""
    Farm._gfPriority = false

    -- v22.2: cek "kirim semua kesini" dulu - kalau ada, SEMUA buah ke akun itu (skip pet & simpanan)
    local prio = Farm.getPriorityTarget()
    if prio and prio ~= player.Name then
        target = prio; Farm._gfToStorage = false; Farm._gfPriority = true
    elseif useRelay then
        local resp = Farm.relayReq({ Url = state.gfRelayUrl, Method = "GET" })
        local body = resp and (resp.Body or resp.body)
        local data
        if body then local ok, d = pcall(function() return HS:JSONDecode(body) end); if ok then data = d end end
        if type(data) ~= "table" or type(data.shk) ~= "number" or not data.nm then
            Farm._gfStatus = "relayerr"; return
        end
        if data.t and (os.time() - data.t) > 300 then Farm._gfStatus = "stale"; return end
        if data.shk >= (state.gfSheckMax or 100000000) then
            -- v22.7: routing ke simpanan cuma kalau gfStorageOn. kalau off -> tahan (priority tetep jalan di atas).
            if not state.gfStorageOn then Farm._gfStatus = "cukup"; return end
            local tgt, err = Farm.pickStorage()
            if tgt then
                target = tgt; Farm._gfToStorage = true
            else
                Farm._gfStatus = (err == "allfull") and "allfull" or "cukup"; return
            end
        else
            target = data.nm   -- AUTO-DETECT penerima = akun yg nulis relay (akun Buy Pet)
            Farm._gfToStorage = false
            Farm._gfRotIdx = 1   -- kepotong buy-pet -> cycle baru, rotasi reset ke awal
        end
    else
        if not target or target == "" then Farm._gfStatus = "notarget"; return end
        -- mode cek sheckles same-server (tanpa relay)
        if state.gfSheckMode then
            local pObj, sh
            for _, p in ipairs(Players:GetPlayers()) do
                if p.Name:lower() == target:lower() or (p.DisplayName and p.DisplayName:lower() == target:lower()) then
                    pObj = p
                    local ls = p:FindFirstChild("leaderstats")
                    local sv = ls and ls:FindFirstChild("Sheckles")
                    if sv then sh = sv.Value end
                    break
                end
            end
            if not pObj then Farm._gfStatus = "offline"; return end
            if sh == nil then Farm._gfStatus = "noshk"; return end
            if sh >= (state.gfSheckMax or 100000000) then
                -- v22.7: routing ke simpanan cuma kalau gfStorageOn
                if not state.gfStorageOn then Farm._gfStatus = "cukup"; return end
                local tgt, err = Farm.pickStorage()
                if tgt then target = tgt; Farm._gfToStorage = true
                else Farm._gfStatus = (err == "allfull") and "allfull" or "cukup"; return end
            else
                Farm._gfToStorage = false; Farm._gfRotIdx = 1
            end
        end
    end

    -- resolve userId penerima (cache by name)
    if not Farm._gfId or Farm._gfIdName ~= target then
        Farm._gfId = resolveTargetId(target)
        Farm._gfIdName = target
        if not Farm._gfId then Farm._gfStatus = "notfound"; print("[ZenxFarm] gift fruit: user '"..tostring(target).."' gak ketemu"); return end
        print("[ZenxFarm] gift fruit target: "..target.." (id "..tostring(Farm._gfId)..")")
    end
    local uid = Farm._gfId
    if not uid then return end
    -- kumpulin fruit dari character + backpack, filter jenis + threshold kg. kirim per batch (max 8).
    local batch, total = {}, 0
    local function flush()
        if #batch > 0 then
            local items = batch; batch = {}
            pcall(function() sb:Fire(uid, items, "") end)
            total = total + #items
            task.wait(0.3)   -- v21.1: dipercepat (dulu 0.5)
        end
    end
    -- v22.9: mode Gift by Value - kirim kombinasi buah yg totalnya >= target (bukan semua).
    -- cuma aktif buat gift manual biasa (bukan routing simpanan/priority).
    local valueModeOn = state.gfValueMode and not Farm._gfToStorage and not Farm._gfPriority
    local pickedSum
    if valueModeOn then
        local picked, sumv = Farm.pickFruitsForValue(state.gfValueTarget or 500000000, state.gfValueMarket)
        if not picked then
            Farm._gfStatus = "kurang"
            print("[ZenxFarm] gift value: total buah cuma "..Farm.abbrev(sumv or 0)..
                " < target "..Farm.abbrev(state.gfValueTarget or 500000000).." -> GAK dikirim (biar gak lebih murah)")
            return
        end
        pickedSum = sumv
        for _, e in ipairs(picked) do
            batch[#batch+1] = { ItemKey = e.fid, Count = 1, Category = "HarvestedFruits" }
            if #batch >= 8 then flush() end
        end
        flush()
    else
    for _, holder in ipairs(invHolders()) do
        if holder then
            for _, t in ipairs(holder:GetChildren()) do
                local fid = t:GetAttribute("Id")
                local fjenis = t:GetAttribute("Fruit") or t:GetAttribute("FruitName")
                if fid and fjenis then
                    local jenisOk = Farm._gfPriority or state.gfAllFruit or state.gfFruits[fjenis]
                    local w = t:GetAttribute("Weight") or 0
                    local valOk = true
                    if Farm._gfPriority then
                        -- v24.0: "Kirim Semua Kesini Dulu" -> cuma buah >= gfPrioMinVal (default 3M), harga NORMAL (x1, ABAIKAN pasar)
                        local pr = Farm.fruitPrice(t, true)
                        valOk = pr and pr >= (state.gfPrioMinVal or 3000000)
                    elseif Farm._gfToStorage then
                        -- ke simpanan: cuma buah bernilai >= batas (4M default)
                        local pr = Farm.fruitPrice(t)
                        valOk = pr and pr >= (state.gfStorageMinVal or 4000000)
                    end
                    local kgOk = Farm._gfPriority or passWeight(w, state.gfWeightF)
                    if jenisOk and valOk and kgOk then
                        batch[#batch+1] = { ItemKey = tostring(fid), Count = 1, Category = "HarvestedFruits" }
                        if #batch >= 8 then flush() end
                    end
                end
            end
        end
    end
    flush()
    end
    if total > 0 then
        Farm._gfStatus = "ok"
        print("[ZenxFarm] gift fruit ke "..target..": "..total.." buah"..
            (valueModeOn and (" = "..Farm.abbrev(pickedSum or 0).." (target "..Farm.abbrev(state.gfValueTarget or 500000000)..")") or "")..
            (Farm._gfPriority and " [PRIORITY]" or Farm._gfToStorage and " [SIMPANAN]" or ""))
        local _ntag = Farm._gfPriority and "PRIORITY" or (Farm._gfToStorage and "SIMPANAN" or "AKUN PET")
        pcall(function() Farm.notif(_ntag, target, total) end)
        -- v22.9: catat ke history gift
        pcall(function() Farm.gfHistAdd({
            to = target, n = total,
            val = valueModeOn and pickedSum or nil,
            tgt = valueModeOn and (state.gfValueTarget or 500000000) or nil,
            mkt = valueModeOn and (state.gfValueMarket and 1 or 0) or nil,
            tag = _ntag,
        }) end)
        -- v21.8: abis kirim ke simpanan -> maju ke akun simpanan berikutnya (rotasi)
        if Farm._gfToStorage then
            local list = Farm.storageList()
            if #list > 0 then Farm._gfRotIdx = (Farm._gfRotIdx % #list) + 1 end
        end
        if state.gfOnce and not state.gfSheckMode then
            state.gfAuto = false
            if Farm._applyGFRef then pcall(Farm._applyGFRef) end
            print("[ZenxFarm] gift fruit sekali kirim -> OFF")
        end
    else
        Farm._gfStatus = "empty"
    end
end
