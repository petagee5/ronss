-- v13.4: kg buah garden = SizeMulti x rasio[jenis]. rasio KONSTAN per jenis.
-- buah garden CUMA punya SizeMulti (gak nyimpen kg langsung - udah dibuktiin via debug),
-- jadi kg HARUS dihitung. rasio di-hardcode (dari kalibrasi) + auto-update dari tas + DISIMPAN
-- ke settings, biar sekali pernah liat jenisnya -> kepake permanen, GAK butuh contoh lagi.
Farm._baseW = {
    ["Dragon's Breath"] = 7.500,  -- terkonfirmasi
    ["Strawberry"] = 1.000,
    ["Blueberry"]  = 1.150,
    ["Tomato"]     = 0.900,
}
Farm._collectKg = 0
Farm._sellKg = 0
function Farm.updateBaseW()
    local changed = false
    for _, holder in ipairs(invHolders()) do
        if holder then
            for _, t in ipairs(holder:GetChildren()) do
                if t:IsA("Tool") then
                    local w = t:GetAttribute("Weight")
                    local sm = t:GetAttribute("SizeMultiplier")
                    if type(w) == "number" and type(sm) == "number" and sm > 0 then
                        local ratio = w / sm
                        -- simpan ke SEMUA nama yg mungkin dipakai garden (Fruit/FruitName/SeedName/CorePartName)
                        for _, key in ipairs({ t:GetAttribute("Fruit"), t:GetAttribute("FruitName"),
                                               t:GetAttribute("SeedName"), t:GetAttribute("CorePartName") }) do
                            if key and math.abs((Farm._baseW[key] or 0) - ratio) > 0.001 then
                                Farm._baseW[key] = ratio; changed = true
                            end
                        end
                    end
                end
            end
        end
    end
    if changed and Farm._saveBaseW then pcall(Farm._saveBaseW) end  -- simpan rasio baru ke settings
end
function Farm.gardenKg(fruit, seedName)
    local w = fruit:GetAttribute("Weight")
    if type(w) == "number" then return w end
    local sm = fruit:GetAttribute("SizeMulti") or fruit:GetAttribute("SizeMultiplier")
    if type(sm) ~= "number" then return nil end
    -- v13.4: CorePartName = kunci jenis paling andal (selalu ada di buah garden).
    local core = fruit:GetAttribute("CorePartName")
    local base = (core and Farm._baseW[core]) or (seedName and Farm._baseW[seedName])
    if not base then return nil end  -- v13.3: BELUM kekalibrasi -> JANGAN tebak (return nil)
    return sm * base
end
