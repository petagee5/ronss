-- v12.9: hitung SEED di tas per jenis (buat ditampilin di picker Jenis Seed Auto Gift)
function Farm.countSeedsInBag()
    local counts = {}
    for _, holder in ipairs(invHolders()) do
        if holder then
            for _, t in ipairs(holder:GetChildren()) do
                if t:IsA("Tool") then
                    local sn = t:GetAttribute("SeedName")
                    if not sn and t.Name:match("Seed%s*$") then sn = t.Name:gsub("%s*Seed%s*$","") end
                    if sn then
                        local cnt = t:GetAttribute("Count") or 1
                        counts[sn] = (counts[sn] or 0) + cnt
                    end
                end
            end
        end
    end
    return counts
end

