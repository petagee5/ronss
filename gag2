    end)
    if #list == 0 then
        -- fallback hardcoded (dari scan)
        list = {"Acorn","Apple","Baby Cactus","Bamboo","Banana","Blueberry","Briar Rose","Cactus","Carrot",
            "Cherry","Coconut","Corn","Dragon Fruit","Dragon's Breath","Ghost Pepper","Glow Mushroom",
            "Gold","Grape","Green Bean","Horned Melon","Hypno Bloom","Mango","Mega","Moon Bloom","Mushroom","Pineapple",
            "Poison Apple","Poison Ivy","Pomegranate","Rainbow","Romanesco","Strawberry","Sunflower",
            "Tomato","Tulip","Venom Spitter","Venus Fly Trap"}
    end
    return list
end

-- v26.3: rarity per seed dari SeedData (buat auto-buy "seed bagus" by tier - auto-include seed baru)
local RARITY_RANK = { Common=1, Uncommon=2, Rare=3, Epic=4, Legendary=5, Mythic=6, Super=7 }
local RARITY_ORDER = { "Super", "Mythic", "Legendary", "Epic", "Rare", "Uncommon", "Common" }  -- buat tombol cycle
local function loadSeedRarity()
    local map = {}
    pcall(function()
        local sm = RS:FindFirstChild("SharedModules")
        local sd = sm and sm:FindFirstChild("SeedData")
        if sd then
            local ok, mod = pcall(require, sd)
            if ok and type(mod) == "table" then
                local src = mod
                if type(mod.Seeds) == "table" then src = mod.Seeds end
                for k, v in pairs(src) do
                    if type(v) == "table" then
                        local nm = (type(k) == "string" and k) or v.SeedName or v.Name
                        if type(nm) == "string" and type(v.Rarity) == "string" then map[nm] = v.Rarity end
