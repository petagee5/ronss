-- v26.8: daftar weather auto-load dari SharedModules.WeatherData (buat picker "weather bagus")
Farm._weatherListCache = nil
function Farm.weatherList()
    if Farm._weatherListCache then return Farm._weatherListCache end
    local list = {}
    pcall(function()
        local sm = RS:FindFirstChild("SharedModules")
        local wd = sm and sm:FindFirstChild("WeatherData")
        if wd then
            local ok, mod = pcall(require, wd)
            if ok and type(mod) == "table" then
                local src = mod
                if type(mod.Weathers) == "table" then src = mod.Weathers elseif type(mod.Data) == "table" then src = mod.Data end
                local seen = {}
                for k, v in pairs(src) do
                    local nm = (type(k) == "string" and not tonumber(k) and k) or (type(v) == "table" and (v.Name or v.WeatherName))
                    if type(nm) == "string" and not seen[nm] then seen[nm] = true; list[#list+1] = nm end
                end
            end
        end
    end)
    -- v35.3: game ini punya event NON-weather juga (fase bulan merah/besar/gold dll) -
    -- ikut scan modul lain di SharedModules yg namanya nyerempet Lunar/Moon/Event/Phase,
    -- ekstraksi pola sama kayak WeatherData.
    pcall(function()
        local RS = game:GetService("ReplicatedStorage")
        local sm = RS:FindFirstChild("SharedModules")
        if not sm then return end
        local have = {}
        for _, n in ipairs(list) do have[n] = true end
        for _, child in ipairs(sm:GetChildren()) do
            local ln = child.Name:lower()
            if child:IsA("ModuleScript") and child.Name ~= "WeatherData"
               and (ln:find("lunar") or ln:find("moon") or ln:find("event") or ln:find("phase")) then
                local ok2, mod2 = pcall(require, child)
                if ok2 and type(mod2) == "table" then
                    local src2 = mod2
                    if type(mod2.Weathers) == "table" then src2 = mod2.Weathers
                    elseif type(mod2.Data) == "table" then src2 = mod2.Data
                    elseif type(mod2.Phases) == "table" then src2 = mod2.Phases end
                    for k, v in pairs(src2) do
                        -- v35.7: cuma entri bernilai TABEL (data event beneran) - field boolean/angka
                        -- kayak IsNaturallySpawnable jangan kejaring jadi "nama event"
                        local nm = nil
                        if type(v) == "table" then
                            nm = (type(k) == "string" and not tonumber(k) and k) or v.Name or v.WeatherName or v.PhaseName
                        end
                        if type(nm) == "string" and not have[nm] then have[nm] = true; list[#list+1] = nm end
                    end
                end
            end
        end
    end)
    -- v35.8: PRE-SEED fase bulan (HASIL BONGKAR REMOTE WeatherEffects: BloodmoonStart/
    -- GoldMoonStrike/RainbowMoonStrike) - bisa ditandai bagus/buruk SEKARANG tanpa nunggu kejadian.
    pcall(function()
        local have = {}
        for _, n in ipairs(list) do have[n] = true end
        for _, ph in ipairs({ "Bloodmoon", "GoldMoon", "RainbowMoon" }) do
            if not have[ph] then list[#list+1] = ph end
        end
    end)
    table.sort(list)
    Farm._weatherListCache = list
    return list
