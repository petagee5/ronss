-- pengali pasar buat 1 jenis buah. v24.3: CACHE pintar - sekali panel kebuka, nilainya
-- dipake terus sepanjang siklus restock itu (5 menit) walau panel ditutup, + tahan rejoin.
-- reset cuma pas restock baru. default 1 kalau belum pernah kebaca di siklus ini.
function Farm.getMarketMult(jenis)
    local now = os.clock()
    local cyc = Farm.stockRestock()
    -- restock baru -> pengali lama udah basi -> reset
    if cyc and Farm._mktCycle and cyc ~= Farm._mktCycle then Farm._mktMap = nil end
    if cyc then Farm._mktCycle = cyc end
    if not Farm._mktMap or (now - Farm._mktAt) > 5 then
        Farm._mktAt = now
        local fresh = Farm.buildMarketMap()
        if next(fresh) ~= nil then
            -- panel lagi ngasih data -> pake + simpen ke file (cap siklus)
            Farm._mktMap = fresh
            Farm.saveMktCache(cyc, fresh)
        elseif not Farm._mktMap then
            -- belum ada map (panel ketutup dr awal) -> coba load cache file (siklus sama)
            Farm._mktMap = Farm.loadMktCache(cyc) or {}
        end
        -- kalau panel ketutup TAPI udah ada map di memori -> biarin (pakai yg lama, jangan dibuang)
    end
    return (jenis and Farm._mktMap and Farm._mktMap[jenis]) or 1
end

-- harga jual 1 buah (Tool inventory ATAU model garden).
-- noMarket=true -> harga NORMAL (x1, abaikan pengali pasar).
function Farm.fruitPrice(fruit, noMarket)
    local jenis = fruit:GetAttribute("Fruit") or fruit:GetAttribute("FruitName") or fruit:GetAttribute("CorePartName")
    local sm = fruit:GetAttribute("SizeMultiplier") or fruit:GetAttribute("SizeMulti")
    if not jenis or type(sm) ~= "number" then return nil end
    local mut = fruit:GetAttribute("Mutation")
    if mut == "" or mut == "None" then mut = nil end
    local decay = fruit:GetAttribute("DecayAlpha")
    local mkt = noMarket and 1 or Farm.getMarketMult(jenis)   -- v22.9: pengali Fruit Price Stock
    -- coba modul eksak dulu
    local fvc = Farm.getFVC()
    if fvc then
        local ok, v = pcall(fvc, jenis, sm, mut, fruit, decay)
        if ok and type(v) == "number" then return math.floor(v * mkt) end
    end
    -- fallback: rumus lama (base x sm^2.5 x mutMult x decay)
    local base = Farm.getSellBase()
    local b = jenis and base[jenis]
    if not b then return nil end
    local price = b * (sm ^ 2.5)
    if mut then price = price * (Farm.getMutMultLive(mut) or Farm._mutMult[mut] or 1) end
    if type(decay) == "number" and decay > 0 then
        price = price * (1 - math.clamp(decay, 0, 1) * 0.8)
    end
    return math.floor(price * mkt)
end

-- v15.4: singkat angka (5.24M, 1.99B)
function Farm.abbrev(n)
    if not n then return "?" end
    if n >= 1e9 then return string.format("%.2fB", n/1e9)
    elseif n >= 1e6 then return string.format("%.2fM", n/1e6)
    elseif n >= 1e3 then return string.format("%.1fK", n/1e3)
    else return tostring(math.floor(n)) end
end

