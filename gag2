-- ====== TOTAL FRUIT: kalkulasi buah di garden (mutasi + range kg) - v21.5 ======
function Farm.calcGarden()
    local res = { total = 0, noMut = 0, mutTotal = 0, muts = {}, ranges = {0,0,0,0,0,0,0,0,0}, value = 0 }
    local gardens = workspace:FindFirstChild("Gardens")
    if not gardens then return res end
    for _, plot in ipairs(gardens:GetChildren()) do
        local plants = plot:FindFirstChild("Plants")
        if plants then
            for _, plant in ipairs(plants:GetChildren()) do
                local ownerId = tonumber(plant.Name:match("^(%d+)_"))
                if ownerId == player.UserId then
                    local fruits = plant:FindFirstChild("Fruits")
                    if fruits then
                        for _, fruit in ipairs(fruits:GetChildren()) do
                            if fruit:IsA("BasePart") or fruit:IsA("Model") then
                                res.total = res.total + 1
                                local mut = fruit:GetAttribute("Mutation")
                                if mut and mut ~= "" and mut ~= "None" then
                                    res.mutTotal = res.mutTotal + 1
                                    res.muts[mut] = (res.muts[mut] or 0) + 1
                                else
                                    res.noMut = res.noMut + 1
                                end
                                local kg = fruit:GetAttribute("Weight")
                                    or (Farm.gardenKg and Farm.gardenKg(fruit, plant:GetAttribute("SeedName"))) or 0
                                local idx
                                if kg < 20 then idx = 1 elseif kg < 30 then idx = 2 elseif kg < 50 then idx = 3
                                elseif kg < 70 then idx = 4 elseif kg < 100 then idx = 5 elseif kg < 150 then idx = 6
                                elseif kg < 200 then idx = 7 elseif kg < 300 then idx = 8 else idx = 9 end
                                res.ranges[idx] = res.ranges[idx] + 1
                                -- v26.5: total value buah di kebun (pakai harga pasar)
                                local v = Farm.fruitPrice and Farm.fruitPrice(fruit, false)
                                if type(v) == "number" then res.value = res.value + v end
                            end
                        end
                    end
                end
            end
        end
    end
    return res
end

