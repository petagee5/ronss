-- ===== AUTO PLANT - format hasil sniff: PlantSeed:Fire(position, seedName, seedTool) =====
-- arg1 = Vector3 posisi tanam, arg2 = nama seed (string), arg3 = Tool seed (di-equip).
-- alur: ambil Tool seed dari Backpack/Character -> equip ke karakter -> fire di posisi.
-- posisi: "self" = sekitar karakter (offset acak kecil biar gak numpuk 1 titik),
--         "random" = acak di area kebun (pakai bounding box plot kamu).
function Farm.plantOnce()
    local p = pkt("Plant", "PlantSeed")
    if not p or not p.Fire then print("[ZenxFarm] PlantSeed packet gak ada"); return end
    local char = player.Character
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not (char and hum and hrp) then return end
    local bp = player:FindFirstChildOfClass("Backpack")

    -- kumpulin Tool seed yg ada (dari Backpack + Character). seed = attr SeedTool / nama cocok.
    local function collectSeedTools()
        local tools = {}
        for _, holder in ipairs({char, bp}) do
            if holder then
                for _, t in ipairs(holder:GetChildren()) do
                    if t:IsA("Tool") then
                        -- nama seed: attr SeedTool, atau dari nama Tool sendiri
                        local seedName = t:GetAttribute("SeedTool") or t.Name
                        if seedName then
                            -- filter pilihan: allPlantSeed=true -> semua; else cuma yg dipilih
                            local ok = state.allPlantSeed or (state.selectedPlant[seedName] == true)
                            if ok then tools[#tools+1] = {tool = t, name = seedName} end
                        end
                    end
                end
            end
        end
        return tools
    end

    -- titik tanam
    local function plantPos()
        -- v12.6: radius sebar bisa diatur (state.plantSpread). 0 = pas di posisi kamu.
        local r = state.plantSpread or 0
        if r <= 0 then return hrp.Position end
        local ox = (math.random() * 2 - 1) * r
        local oz = (math.random() * 2 - 1) * r
        return hrp.Position + Vector3.new(ox, 0, oz)
    end

    local seeds = collectSeedTools()
    if #seeds == 0 then return end  -- gak ada seed cocok di inventory

    local planted = 0
    for _, s in ipairs(seeds) do
        if not state.autoPlant then break end
        -- v6.5: BRUTAL - fire langsung tanpa equip & tanpa wait per-seed.
        -- (dari sniff, arg3 cukup referensi Tool; gak wajib di-equip dulu)
        local pos = plantPos()
        pcall(function() p:Fire(pos, s.name, s.tool) end)
        planted = planted + 1
    end
    if planted > 0 then dprint("[ZenxFarm] plant: "..planted.." seed (loc="..tostring(state.plantLocation)..")") end
end
