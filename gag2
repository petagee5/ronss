Farm.buyPerSeed = 4   -- tiap seed di-fire berapa kali per siklus (kurangi biar gak lag)
function Farm.buySeedOnce()
    local p = pkt("SeedShop", "PurchaseSeed")
    if not p or not p.Fire then print("[ZenxFarm] PurchaseSeed packet gak ada"); return end
    if not Farm.seedList then Farm.seedList = loadSeedList(); print("[ZenxFarm] seed list: "..#Farm.seedList.." seed") end
    local list = Farm.seedList
    -- kalau bukan "borong semua", filter cuma yg dipilih
    if not state.buyAllSeeds then
        local sel = {}
        for _, name in ipairs(list) do if state.selectedSeeds[name] then sel[#sel+1] = name end end
        -- v26.3: auto-beli "seed bagus" by rarity (auto-include seed baru ber-tier tinggi, tanpa update)
        if state.buyGoodSeeds then
            local minRank = RARITY_RANK[state.buyGoodMinRarity or "Mythic"] or 6
            local seen = {}
            for _, n in ipairs(sel) do seen[n] = true end
            for _, n in ipairs(Farm.seedList) do
                if not seen[n] and Farm.seedRarityRank(n) >= minRank then sel[#sel+1] = n; seen[n] = true end
            end
        end
        list = sel
    end
    if #list == 0 then return end
    -- v11.6: CEK STOK SERVER - cuma beli yg stok > 0, sebanyak stoknya. yg kosong di-skip.
    -- nama stok tanpa "Seed" (Carrot, bukan Carrot Seed) -> coba 2 bentuk nama.
    local fired = 0
    for _, name in ipairs(list) do
        if not state.autoBuySeed then break end
        local short = name:gsub("%s*Seed$", "")  -- "Carrot Seed" -> "Carrot"
        local stok = Farm.getStock("SeedShop", short)
        if stok == nil then stok = Farm.getStock("SeedShop", name) end
        if stok and stok > 0 then
            if stok > 20 then stok = 20 end  -- v12.0: batasi max 20 per siklus (safety)
            for _ = 1, stok do  -- fire sebanyak stok
                if not state.autoBuySeed then break end
                pcall(function() p:Fire(name) end)
                fired = fired + 1
                if fired % 5 == 0 then task.wait() end  -- v12.0: jeda tiap 5 fire (dulu tiap fire -> lama/lag)
            end
        end
    end
    if fired > 0 then dprint("[ZenxFarm] buy seed: "..fired.." fire (cuma yg ada stok)") end
end

-- v7.1: AUTO BUY GEAR - beli alat/gear dari gear shop.
-- v7.4: list gear sekarang dari SUMBER ASLI game (lengkap):
--   1) StockValues.GearShop.Items (stok toko yg lagi ada)
--   2) parse Workspace.RemoteDeveloperProducts (semua entri "Gear:")
-- CATATAN: remote BELI gear masih kandidat (perlu sniff kalau gak jalan).
local function loadGearList()
    local seen, list = {}, {}
    local function addName(nm)
        if type(nm) == "string" and nm ~= "" and not seen[nm] then
            seen[nm] = true; list[#list+1] = nm
        end
    end
    -- 1) stok gear shop (paling akurat - gear yg beneran ada di toko)
    pcall(function()
        local sv = RS:FindFirstChild("StockValues")
        local gs = sv and sv:FindFirstChild("GearShop")
        local items = gs and gs:FindFirstChild("Items")
        if items then for _, it in ipairs(items:GetChildren()) do addName(it.Name) end end
    end)
    -- 2) parse RemoteDeveloperProducts: entri format "Gear:<Nama>:<qty>"
    pcall(function()
        local raw = workspace:GetAttribute("RemoteDeveloperProducts")
        if type(raw) == "string" then
            -- ambil tiap "Gear:Nama:..." -> Nama (tanpa qty/Gift)
            for name in raw:gmatch('"Gear:([^:"]+):') do addName(name) end
        end
    end)
    -- 3) fallback terakhir (kalau dua-duanya kosong)
    if #list == 0 then
        list = {"Common Watering Can","Super Watering Can","Trowel","Common Sprinkler",
            "Uncommon Sprinkler","Rare Sprinkler","Legendary Sprinkler","Super Sprinkler",
            "Basic Pot","Gnome","Trowel","Speed Mushroom","Shrink Mushroom","Supersize Mushroom",
            "Jump Mushroom","Invisibility Mushroom","Flashbang","Lantern","Sign","Teleporter",
            "Wheelbarrow","Cleaning Spray","Favorite Tool","Harvest Tool","Friendship Pot"}
        local s2 = {}; for _, n in ipairs(list) do if not s2[n] then s2[n]=true end end
    end
    return list
end

