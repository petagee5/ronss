-- v21.6: baca multiplier mutasi LIVE dari modul game (otomatis tau semua mutasi termasuk Aurora)
Farm._mutData = nil
function Farm.getMutMultLive(mut)
    if Farm._mutData == nil then
        Farm._mutData = false
        pcall(function()
            local md = RS:FindFirstChild("SharedModules") and RS.SharedModules:FindFirstChild("MutationData")
            if md then
                local ok, data = pcall(require, md)
                if ok and type(data) == "table" then Farm._mutData = data end
            end
        end)
    end
    local d = Farm._mutData
    if not d or not mut or type(d.ReturnPriceMultiplier) ~= "function" then return nil end
    -- coba beberapa cara panggil (fungsi biasa / method / argumen list)
    for _, args in ipairs({ {mut}, {d, mut}, {{mut}}, {d, {mut}} }) do
        local ok, v = pcall(function() return d.ReturnPriceMultiplier(table.unpack(args)) end)
        if ok and type(v) == "number" and v > 0 then return v end
    end
    return nil
end
function Farm.getSellBase()
    if Farm._sellBase == nil then
        Farm._sellBase = {}
