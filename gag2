-- v11.4: ANTI-LAG agresif - matiin efek visual berat. _antiLagOn nandain status.
Farm._antiLagOn = false
Farm._antiLagConn = nil
function Farm.applyAntiLagToObj(d)
    pcall(function()
        if d:IsA("ParticleEmitter") or d:IsA("Trail") or d:IsA("Beam")
           or d:IsA("Smoke") or d:IsA("Fire") or d:IsA("Sparkles") then
            d.Enabled = false
        elseif d:IsA("Explosion") then
            d.Visible = false
        elseif d:IsA("PostEffect") then  -- Bloom/Blur/ColorCorrection/DepthOfField/SunRays
            d.Enabled = false
        elseif d:IsA("MaterialVariant") then
        end
    end)
end
function Farm.setAntiLag(on)
    local Light = game:GetService("Lighting")
    local run = game:GetService("RunService")
    if on then
        Farm._antiLagOn = true
        pcall(function()
            -- v32.7: simpen kualitas ASLI sekali (biar bisa dibalikin pas OFF)
            if Farm._origQuality == nil then Farm._origQuality = settings().Rendering.QualityLevel end
            -- kualitas grafis minimum (INI yg bikin bentuk buah jadi low-poly: mesh LOD level 1)
            settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
        end)
        pcall(function()
            local sg = game:GetService("UserGameSettings") or UserSettings():GetService("UserGameSettings")
            if sg then
                if Farm._origSavedQuality == nil then Farm._origSavedQuality = sg.SavedQualityLevel end   -- v32.7
                sg.SavedQualityLevel = Enum.SavedQualitySetting.QualityLevel1
            end
        end)
        -- lighting: matiin efek berat
        pcall(function()
            Light.GlobalShadows = false
            Light.FogEnd = 1e6
            Light.Brightness = 1
            for _, e in ipairs(Light:GetChildren()) do
                if e:IsA("PostEffect") or e:IsA("Atmosphere") or e:IsA("Sky") then pcall(function() e.Enabled = false end) end
                if e:IsA("Atmosphere") then pcall(function() e:Destroy() end) end
            end
        end)
        -- matiin SEMUA partikel/trail/beam yg ada + Terrain detail
        pcall(function()
            for _, d in ipairs(workspace:GetDescendants()) do Farm.applyAntiLagToObj(d) end
        end)
        pcall(function()
            local ter = workspace:FindFirstChildOfClass("Terrain")
            if ter then ter.WaterWaveSize = 0; ter.WaterWaveSpeed = 0; ter.WaterReflectance = 0; ter.WaterTransparency = 1 end
        end)
        -- listener: efek baru yg muncul langsung dimatiin
        if not Farm._antiLagConn then
            Farm._antiLagConn = workspace.DescendantAdded:Connect(function(d)
                if Farm._antiLagOn then Farm.applyAntiLagToObj(d) end
            end)
        end
        print("[ZenxFarm] anti-lag ON (efek visual dimatiin, max enteng)")
    else
        Farm._antiLagOn = false
        if Farm._antiLagConn then Farm._antiLagConn:Disconnect(); Farm._antiLagConn = nil end
        -- v32.7: balikin kualitas grafis (dulu GAK dibalikin -> buah nyangkut low-poly permanen,
        -- SavedQualityLevel itu setting akun yg ke-save, rejoin pun gak balik)
        pcall(function()
            settings().Rendering.QualityLevel = Farm._origQuality or Enum.QualityLevel.Automatic
        end)
        pcall(function()
            local sg = game:GetService("UserGameSettings") or UserSettings():GetService("UserGameSettings")
            if sg then sg.SavedQualityLevel = Farm._origSavedQuality or Enum.SavedQualitySetting.Automatic end
        end)
        pcall(function()
            Light.GlobalShadows = true
            for _, e in ipairs(Light:GetChildren()) do
                if e:IsA("PostEffect") or e:IsA("Sky") then pcall(function() e.Enabled = true end) end
            end
        end)
        print("[ZenxFarm] anti-lag OFF (efek balik normal, perlu rejoin biar full balik)")
    end
end

-- v11.7: SEMBUNYIIN VISUAL TANAMAN (buah TETEP keliatan). ngurangin beban render berat.
-- cara: di tiap plant Model, set part jadi transparan - KECUALI yg di folder Fruits.
Farm._hidePlantsOn = false
Farm._hidePlantsConn = nil
function Farm.hidePlantParts(plant, hide)
    pcall(function()
        local fruits = plant:FindFirstChild("Fruits")
        for _, d in ipairs(plant:GetDescendants()) do
            if d:IsA("BasePart") or d:IsA("Decal") or d:IsA("Texture") then
                -- skip kalau bagian dari folder Fruits (biar buah tetep keliatan)
                local inFruit = false
                if fruits then
                    local par = d
                    while par and par ~= plant do
                        if par == fruits then inFruit = true; break end
                        par = par.Parent
                    end
                end
                if not inFruit then
                    if hide then
                        -- simpan transparency ASLI sekali (biar rainbow/gold ga rusak pas dibalikin)
                        if d:GetAttribute("ZenxOrigT") == nil then d:SetAttribute("ZenxOrigT", d.Transparency) end
                        d.Transparency = 1
                    else
                        local o = d:GetAttribute("ZenxOrigT")
                        d.Transparency = (type(o) == "number") and o or 0
                        d:SetAttribute("ZenxOrigT", nil)
                    end
                end
            end
        end
    end)
end
function Farm.setHidePlants(on)
    local gardens = workspace:FindFirstChild("Gardens")
    Farm._hidePlantsOn = on
    if gardens then
        -- v11.9: scan BERTAHAP (jeda tiap 20 tanaman) biar gak freeze pas awal
        local cnt = 0
        for _, plot in ipairs(gardens:GetChildren()) do
            local plants = plot:FindFirstChild("Plants")
            if plants then
                for _, plant in ipairs(plants:GetChildren()) do
                    Farm.hidePlantParts(plant, on)
                    cnt = cnt + 1
                    if cnt % 20 == 0 then task.wait() end  -- napas tiap 20 tanaman
                end
            end
        end
    end
    if on then
        -- listener: tanaman baru yg muncul ikut disembunyiin
        if not Farm._hidePlantsConn then
            Farm._hidePlantsConn = workspace.DescendantAdded:Connect(function(d)
                if Farm._hidePlantsOn and d.Parent and d.Parent.Name == "Plants" then
                    task.wait(0.1)
                    Farm.hidePlantParts(d, true)
                end
            end)
        end
        print("[ZenxFarm] sembunyiin pohon ON (buah tetep keliatan)")
    else
        if Farm._hidePlantsConn then Farm._hidePlantsConn:Disconnect(); Farm._hidePlantsConn = nil end
        print("[ZenxFarm] sembunyiin pohon OFF")
    end
end

