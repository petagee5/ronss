-- cek apakah weather skrg "buruk" (ada event & BUKAN yg ditandai bagus). neutral/cerah = bukan buruk.
-- v35.1: ActiveWeather di game ini TERMASUK siklus siang-malam (bukti log spy: Day/Sunset/Moon)!
-- semua state siklus harian = NETRAL, jangan pernah dianggap weather buruk.
local WEATHER_NEUTRAL = { none=true, normal=true, standard=true, clear=true, sunny=true, default=true, [""]=true,
    day=true, night=true, moon=true, sunset=true, sunrise=true, dawn=true, dusk=true,
    morning=true, noon=true, evening=true, midnight=true }
function Farm.isBadWeatherNow()
    -- v35.4 (HASIL BONGKAR DATA): game punya DUA kanal terpisah -
    --   ActiveWeather = weather (Rain/Lightning/Rainbow/Snowfall/Starfall/Aurora/Sunburst)
    --   ActivePhase   = FASE (siklus harian + fase bulan merah/besar/gold)
    -- dua-duanya dicek. nilai non-netral yg belum ditandai bagus = BURUK.
    -- nama fase ga perlu diketahui di muka: nilai baru otomatis didaftarin ke picker.
    local cands = {}
    local aw = workspace:GetAttribute("ActiveWeather"); if aw ~= nil then cands[#cands+1] = aw end
    local ap = workspace:GetAttribute("ActivePhase");   if ap ~= nil then cands[#cands+1] = ap end
    -- v35.8: pencocokan tanda "bagus" KEBAL EJAAN - attribute bisa "Blood Moon"/"BloodMoon"/
    -- "Bloodmoon", picker nyimpen salah satunya; huruf besar/kecil & spasi/simbol diabaikan.
    local function norm(s) return tostring(s):lower():gsub("[^%w]", "") end
    local goodNorm = {}
    if state.goodWeathers then for n in pairs(state.goodWeathers) do goodNorm[norm(n)] = true end end
    for _, w in ipairs(cands) do
        local wl = tostring(w):lower()
        if not WEATHER_NEUTRAL[wl] then
            -- v35.3: BELAJAR SENDIRI - nilai baru (weather ataupun fase) didaftarin ke picker
            pcall(function()
                local ws = tostring(w)
                local lc = Farm._weatherListCache
                if lc then
                    for _, n in ipairs(lc) do if norm(n) == norm(ws) then return end end
                    lc[#lc+1] = ws; table.sort(lc)
                    print("[ZenxFarm] event baru kedeteksi & didaftarin ke picker: "..ws)
                end
            end)
            if not state.allGoodWeather and not goodNorm[norm(w)] then
                return true, w
            end
        end
    end
    return false, aw
end

