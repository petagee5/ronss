                    -- masih loading kalau belum 100%
                    if not t:find("100") then return true end
                end
            end
        end
        return false
    end

    task.wait(1)  -- jeda awal kecil: kasih game waktu mulai load (jangan nembak dari frame 0)
    for _ = 1, 200 do  -- max ~60 detik (spam tiap 0.3s)
