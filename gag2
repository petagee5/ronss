-- v22.9: pilih kombinasi buah yg TOTAL nilainya >= targetVal, overage sekecil mungkin.
-- algoritma: ambil termahal dulu sampe nembus target (dijamin >= target, gak bakal lebih murah),
-- terus buang buah redundan (yg nilainya <= overage) biar selisih makin tipis.
-- return: list {fid,val}, totalNilai  ATAU  nil, totalSemua (kalau gak nyampe target).
function Farm.pickFruitsForValue(targetVal, useMarket, allowPartial)
    local elig = {}
    for _, holder in ipairs(invHolders()) do
        if holder then
            for _, t in ipairs(holder:GetChildren()) do
                local fid = t:GetAttribute("Id")
                local fjenis = t:GetAttribute("Fruit") or t:GetAttribute("FruitName")
                if fid and fjenis then
                    local jenisOk = state.gfAllFruit or state.gfFruits[fjenis]
                    local w = t:GetAttribute("Weight") or 0
                    if jenisOk and passWeight(w, state.gfWeightF) then
                        local pr = Farm.fruitPrice(t, not useMarket) or 0   -- useMarket=false -> harga normal x1
                        if pr > 0 then elig[#elig+1] = { fid = tostring(fid), val = pr, jenis = fjenis, kg = w } end
                    end
                end
            end
        end
    end
    table.sort(elig, function(a, b) return a.val > b.val end)
    local picked, sum = {}, 0
    for _, e in ipairs(elig) do
        if sum >= targetVal then break end
        picked[#picked+1] = e; sum = sum + e.val
    end
    if sum < targetVal then
        if allowPartial then return picked, sum, false end   -- kirim semua yg ada (partial top-up)
        return nil, sum, false                               -- strict: jangan jual lebih murah
    end
    -- buang buah redundan biar overage mengecil (tetap >= target)
    while true do
        local overage = sum - targetVal
        local bestIdx, bestVal
        for i, e in ipairs(picked) do
            if e.val <= overage and (not bestVal or e.val > bestVal) then bestVal = e.val; bestIdx = i end
        end
        if bestIdx then sum = sum - picked[bestIdx].val; table.remove(picked, bestIdx) else break end
    end
    return picked, sum, true
end

-- v22.9: pilih SATU buah paling pas buat sisa target (buat kirim satu-satu).
-- v23.4: mode urutan: "besar" = buah nilai TERBESAR dulu, "kecil" = TERKECIL dulu,
--        nil/default = best-fit (terbesar yg <= sisa, kalau ga ada ambil terkecil).
function Farm.pickOneForValue(remaining, useMarket, mode, range)
    local best, under, biggest   -- best=terkecil nilai, under=terbesar yg <=sisa, biggest=terbesar nilai
    for _, holder in ipairs(invHolders()) do
        if holder then
            for _, t in ipairs(holder:GetChildren()) do
                local fid = t:GetAttribute("Id")
                local fjenis = t:GetAttribute("Fruit") or t:GetAttribute("FruitName")
                if fid and fjenis then
                    local jenisOk = state.gfAllFruit or state.gfFruits[fjenis]
                    local w = t:GetAttribute("Weight") or 0
                    if jenisOk and passWeight(w, state.gfWeightF) then
                        local pr = Farm.fruitPrice(t, not useMarket) or 0
                        local inRange = (not range) or (pr >= range[1] and pr <= range[2])  -- v23.5
                        if pr > 0 and inRange then
                            local e = { fid = tostring(fid), val = pr, jenis = fjenis, kg = w }
                            if not best or pr < best.val then best = e end
                            if not biggest or pr > biggest.val then biggest = e end
                            if pr <= remaining and (not under or pr > under.val) then under = e end
                        end
                    end
                end
            end
        end
    end
    if mode == "besar" then return biggest or best end
    if mode == "kecil" then return best end
    return under or best
end

