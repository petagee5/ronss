-- list jenis fruit di tas (urut terbanyak)
function Farm.fruitsInBagList()
    local c = Farm.countFruitsInBag()
    local arr = {}
    for nm, n in pairs(c) do arr[#arr+1] = {nm, n} end
    table.sort(arr, function(a,b) return a[2] > b[2] end)
    local names = {}
    for _, e in ipairs(arr) do names[#names+1] = e[1] end
    return names
end

-- v14.4: hitung GEAR di tas per jenis (buat picker Gift Langsung - kirim gear yg dipegang).
-- gear = Tool yg BUKAN seed (no SeedTool), BUKAN pet (no PetId), BUKAN fruit (no Id+Fruit).
-- nama jenis = Tool.Name.
local function isGearTool(t)
    if not t:IsA("Tool") then return false end
    if t:GetAttribute("SeedTool") then return false end       -- seed
    if t:GetAttribute("PetId") or t:GetAttribute("Pet") then return false end  -- pet
    local fid = t:GetAttribute("Id")
    local fj  = t:GetAttribute("Fruit") or t:GetAttribute("FruitName")
    if fid and fj then return false end                       -- fruit
    return true
end
function Farm.countGearInBag()
    local counts = {}
    for _, holder in ipairs(invHolders()) do
        if holder then
            for _, t in ipairs(holder:GetChildren()) do
                if isGearTool(t) then
                    local nm = t.Name
                    counts[nm] = (counts[nm] or 0) + 1
                end
            end
        end
    end
    return counts
end
function Farm.gearInBagList()
    local c = Farm.countGearInBag()
    local arr = {}
    for nm, n in pairs(c) do arr[#arr+1] = {nm, n} end
    table.sort(arr, function(a,b) return a[2] > b[2] end)
    local names = {}
    for _, e in ipairs(arr) do names[#names+1] = e[1] end
    return names
end
