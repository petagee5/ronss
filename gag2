    sub.Position = UDim2.new(0, 14, 0, 30); sub.Size = UDim2.new(1, -28, 0, 14)

    local rowWeather = lbl(card, "Cuaca: -", 12, C.text, Enum.TextXAlignment.Left)
    rowWeather.Position = UDim2.new(0, 14, 0, 52); rowWeather.Size = UDim2.new(1, -28, 0, 16)
    local rowPhase = lbl(card, "Fase: -", 12, C.textDim, Enum.TextXAlignment.Left)
    rowPhase.Position = UDim2.new(0, 14, 0, 72); rowPhase.Size = UDim2.new(1, -28, 0, 16)
    local rowSeed = lbl(card, "Restock Seed: -", 12, C.text, Enum.TextXAlignment.Left)
    rowSeed.Position = UDim2.new(0, 14, 0, 96); rowSeed.Size = UDim2.new(1, -28, 0, 16)
    local rowGear = lbl(card, "Restock Gear: -", 12, C.text, Enum.TextXAlignment.Left)
    rowGear.Position = UDim2.new(0, 14, 0, 116); rowGear.Size = UDim2.new(1, -28, 0, 16)
    local rowCrate = lbl(card, "Restock Crate: -", 12, C.text, Enum.TextXAlignment.Left)
    rowCrate.Position = UDim2.new(0, 14, 0, 136); rowCrate.Size = UDim2.new(1, -28, 0, 16)

    local function fmtLeft(sec)
        if sec == nil then return "-" end
        if sec < 0 then sec = 0 end
        local m = math.floor(sec / 60); local s = math.floor(sec % 60)
        if m > 60 then
            local h = math.floor(m/60); m = m % 60
            return string.format("%dj %dm", h, m)
        end
        return string.format("%dm %02ds", m, s)
    end
    local function getRestockLeft(shop)
        local sv = RS:FindFirstChild("StockValues")
        if not sv then return nil end
        local s = sv:FindFirstChild(shop)
        if not s then return nil end
        local nx = s:FindFirstChild("UnixNextRestock")
        if not nx then return nil end
        return tonumber(nx.Value) - os.time()
    end

    task.spawn(function()
        while isCurrentGen() do
            pcall(function()
                local w = workspace:GetAttribute("ActiveWeather")
                local ph = workspace:GetAttribute("ActivePhase")
                local pend = workspace:GetAttribute("PhaseDuration")  -- timestamp akhir fase
                rowWeather.Text = "Cuaca: "..tostring(w or "-")
                -- warnain cuaca spesial
                local wl = tostring(w):lower()
                if wl:find("rain") or wl:find("moon") or wl:find("blood") or wl:find("gold") then
                    rowWeather.TextColor3 = C.green
                else
                    rowWeather.TextColor3 = C.text
                end
                local phLeft = pend and (tonumber(pend) - os.time()) or nil
                rowPhase.Text = "Fase: "..tostring(ph or "-")..(phLeft and ("  (ganti "..fmtLeft(phLeft)..")") or "")
                rowSeed.Text  = "Restock Seed: "..fmtLeft(getRestockLeft("SeedShop"))
                rowGear.Text  = "Restock Gear: "..fmtLeft(getRestockLeft("GearShop"))
                rowCrate.Text = "Restock Crate: "..fmtLeft(getRestockLeft("CrateShop"))
            end)
            task.wait(1)
        end
    end)
end

