-- ===== AUTO STEAL: curi buah garden orang lain =====
-- Steal.BeginSteal:Fire(ownerUserId, plantUUID, fruitUUID) lalu CompleteSteal:Fire()
-- garden orang: Workspace.Gardens.Plot*.Plants.<ownerId>_<plantUUID>.Fruits.<...>_<fruitUUID>
-- ownerId != userId kita = punya orang.
local MY_UID = player.UserId
function Farm.stealOnce()
    local bg = pkt("Steal", "BeginSteal")
    local cp = pkt("Steal", "CompleteSteal")
    if not bg or not bg.Fire or not cp or not cp.Fire then return end
    local gardens = workspace:FindFirstChild("Gardens")
    if not gardens then return end
    local char = player.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    local stolen = 0
    for _, plot in ipairs(gardens:GetChildren()) do
        local plants = plot:FindFirstChild("Plants")
        if plants then
            for _, plant in ipairs(plants:GetChildren()) do
                if stolen >= 15 then break end
                -- ambil ownerId dari nama plant "<ownerId>_<plantUUID>"
                local ownerId = tonumber(plant.Name:match("^(%d+)_"))
                local plantId = plant:GetAttribute("PlantId")
                -- cuma garden ORANG (ownerId != kita)
                if ownerId and ownerId ~= MY_UID and plantId then
                    local fruits = plant:FindFirstChild("Fruits")
                    if fruits then
                        for _, fruit in ipairs(fruits:GetChildren()) do
                            local fruitUUID = fruit:GetAttribute("FruitId") or fruit.Name:match("_([%x%-]+)$")
                            if fruitUUID and #tostring(fruitUUID) >= 30 then
                                -- teleport ke buah (proximity steal) - opsional
                                if state.stealTeleport and hrp then
                                    local fp = fruit:IsA("BasePart") and fruit
                                        or (fruit:IsA("Model") and (fruit.PrimaryPart or fruit:FindFirstChildWhichIsA("BasePart")))
                                    if fp then pcall(function() hrp.CFrame = fp.CFrame + Vector3.new(0,3,0) end); task.wait(0.1) end
                                end
                                pcall(function() bg:Fire(ownerId, tostring(plantId), tostring(fruitUUID)) end)
                                task.wait()
                                pcall(function() cp:Fire() end)
                                stolen = stolen + 1
                                task.wait(0.15)
                            end
                        end
                    end
                end
            end
        end
    end
    if stolen > 0 then print("[ZenxFarm] steal: "..stolen.." buah") end
end

