-- alur: place sprinkler MANUAL -> tiap placement kerekam jadi entri "jenis + posisi".
-- entri muncul di picker MULTI-SELECT. auto place cuma di posisi yg DIPILIH.
-- format remote: Place.PlaceSprinkler(pos_Vector3, name_string, tool_Instance, num)

local SPRINKLER_TYPES = {"Common Sprinkler","Uncommon Sprinkler","Rare Sprinkler",
    "Legendary Sprinkler","Super Sprinkler","Master Sprinkler","Godly Sprinkler"}
state.sprCoords = state.sprCoords or {}   -- list {x,y,z,name}
local SPR_COOLDOWN = 90  -- detik sebelum place lagi di koordinat sama
Farm._sprPlacedAt = {}   -- [label] = tick() terakhir place
Farm._sprAutoPlacing = false  -- true pas auto-place (biar gak kerekam sbg manual)

-- label unik tiap koordinat buat picker: "Jenis (x,z)"
function Farm.sprLabel(c)
    return string.format("%s (%d,%d)", tostring(c.name), math.floor(c.x), math.floor(c.z))
end
-- list label semua koordinat tersimpan (buat picker)
function Farm.sprPosList()
    local out = {}
    for _, c in ipairs(state.sprCoords) do out[#out+1] = Farm.sprLabel(c) end
    return out
end

-- HOOK PlaceSprinkler: rekam tiap player place MANUAL (pas Save Position ON)
Farm.sprRecording = false
do
    local p = pkt("Place", "PlaceSprinkler")
    if p and p.Fire then
        local orig = p.Fire
        p.Fire = function(self, pos, name, tool, num, ...)
            -- rekam hanya kalau: mode rekam ON, BUKAN auto-place kita, pos valid
            if Farm.sprRecording and not Farm._sprAutoPlacing and typeof(pos) == "Vector3" then
                -- dedupe: skip kalau udah ada koordinat dekat (<3 stud) dgn nama sama
                local dup = false
                for _, c in ipairs(state.sprCoords) do
                    if c.name == tostring(name)
                       and math.abs(c.x - pos.X) < 3 and math.abs(c.z - pos.Z) < 3 then dup = true; break end
                end
                if not dup then
                    local c = { x = pos.X, y = pos.Y, z = pos.Z, name = tostring(name) }
                    state.sprCoords[#state.sprCoords+1] = c
                    state.selectedSprPos[Farm.sprLabel(c)] = true  -- auto-pilih yg baru direkam
                    saveState()
                    print("[ZenxFarm] sprinkler DIREKAM: "..Farm.sprLabel(c))
                    if Farm._sprOnRecord then pcall(Farm._sprOnRecord) end
                end
            end
            return orig(self, pos, name, tool, num, ...)
        end
    end
end

function Farm.findSprinklerTool(wantName)
    local char = player.Character
    local anySpr = nil
    for _, h in ipairs({ char, player:FindFirstChildOfClass("Backpack") }) do
        if h then
            for _, t in ipairs(h:GetChildren()) do
                if t:IsA("Tool") and t.Name:lower():find("sprinkler") then
                    if wantName and t.Name == wantName then return t end
                    anySpr = anySpr or t
                end
            end
        end
    end
    return anySpr
end

function Farm.placeSprinklerOnce()
    local p = pkt("Place", "PlaceSprinkler")
    if not p or not p.Fire then return end
    if #state.sprCoords == 0 then dprint("[ZenxFarm] sprinkler: belum ada posisi (place manual + Save Position dulu)"); return end
    local char = player.Character
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    if not char then return end

    local placed = 0
    for _, c in ipairs(state.sprCoords) do
        if not state.autoSprinkler then break end
        local label = Farm.sprLabel(c)
        -- cuma posisi yg DIPILIH di picker
        if state.selectedSprPos[label] == true then
            local last = Farm._sprPlacedAt[label]
            if not last or (tick() - last) >= SPR_COOLDOWN then
                local tool = Farm.findSprinklerTool(c.name)
                if tool then
                    if tool.Parent ~= char and hum then pcall(function() hum:EquipTool(tool) end); task.wait(0.1) end
                    Farm._sprAutoPlacing = true  -- tandai biar gak kerekam ulang
                    pcall(function() p:Fire(Vector3.new(c.x, c.y, c.z), tool.Name, tool, 1) end)
                    Farm._sprAutoPlacing = false
                    Farm._sprPlacedAt[label] = tick()
                    placed = placed + 1
                    dprint("[ZenxFarm] sprinkler place: "..label.." ("..tool.Name..")")
                    task.wait(0.2)
                else
                    dprint("[ZenxFarm] sprinkler: stok habis")
                    break
                end
            end
        end
    end
    if placed > 0 then dprint("[ZenxFarm] sprinkler: place "..placed.." titik") end
end
staggerSpawn(function()
    while isCurrentGen() do
        pcall(function()
            task.wait(3)
            if isCurrentGen() and state.autoSprinkler then Farm.placeSprinklerOnce() end
        end)
    end
end)

