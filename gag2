}
-- kirim buah via MAILBOX (SendBatch). filter jenis + range nilai/buah, kumpulin kombinasi sampai >= target.
Farm._mailSent = Farm._mailSent or {}   -- fid yg udah dikirim sesi ini (biar ga dobel/ulang)
Farm._mailSentVal = Farm._mailSentVal or {}   -- v32.5: fid -> value yg keitung terkirim (buat reconcile bounce)
function Farm.mailGiftSend(target, fruitFilter, rngLo, rngHi, cap, useMarket)
    local sb = pkt("Mailbox", "SendBatch")
    if not sb or not sb.Fire then return false, "Mailbox SendBatch gak ada" end
    if not target or target == "" then return false, "target kosong" end
    local uid = resolveTargetId(target)
    if not uid then return false, "target '"..tostring(target).."' gak ketemu" end
    Farm._mailSentVal = Farm._mailSentVal or {}
    -- cek fid masih ada di tas (Character + Backpack)
    local function fidInBag(fid)
        for _, holder in ipairs(invHolders()) do
            if holder then
                for _, t in ipairs(holder:GetChildren()) do
                    if tostring(t:GetAttribute("Id") or "") == fid then return true end
                end
            end
        end
        return false
    end
    -- v32.5: REKONSILIASI bounce - buah yg ditandai 'terkirim' tapi BALIK ke tas (mailbox penerima penuh)
    -- di-unmark biar dikirim ulang, & value-nya dikeluarin dari total (counter jujur, ga nyangkut).
    for fid in pairs(Farm._mailSent) do
        if fidInBag(fid) then Farm._mailSent[fid] = nil; Farm._mailSentVal[fid] = nil end
    end
    local function cumVal() local s, n = 0, 0; for _, v in pairs(Farm._mailSentVal) do s = s + v; n = n + 1 end; return s, n end
    local ff = tostring(fruitFilter or ""):lower():gsub("^%s+",""):gsub("%s+$","")
    local allFruit = (ff == "" or ff == "semua" or ff == "all")
    local elig = {}
    for _, holder in ipairs(invHolders()) do
        if holder then
            for _, t in ipairs(holder:GetChildren()) do
                local fid = t:GetAttribute("Id")
                local fj = t:GetAttribute("Fruit") or t:GetAttribute("FruitName")
                if fid and fj and not Farm._mailSent[tostring(fid)] then   -- skip yg udah dikirim
                    local jenisOk = allFruit or (tostring(fj):lower() == ff)
                    if jenisOk then
                        -- v28.6: filter range pakai NORMAL price (biar match sama tampilan ESP inventory).
                        -- market price (useMarket) cuma buat ngumpulin sum akumulasi ke target.
                        local prNorm = Farm.fruitPrice(t, true) or 0   -- NORMAL selalu buat filter
                        local prSend = useMarket and (Farm.fruitPrice(t, false) or 0) or prNorm
                        if prNorm >= rngLo and prNorm <= rngHi then
                            elig[#elig+1] = { fid = tostring(fid), val = prSend }
                        end
                    end
                end
            end
        end
    end
    if #elig == 0 then return false, "ga ada buah cocok", cumVal() end
    table.sort(elig, function(a, b) return a.val > b.val end)   -- nilai terbesar dulu
    -- v32.3/32.5: SATU batch per panggilan (max 20 buah), DIVERIFIKASI + reconcile bounce di atas.
    local picked, sum = {}, 0
    for _, e in ipairs(elig) do
        if sum >= cap or #picked >= 20 then break end   -- max 20 buah / panggilan (1 batch)
        picked[#picked+1] = e; sum = sum + e.val
    end
    local items = {}
    for _, e in ipairs(picked) do items[#items+1] = { ItemKey = e.fid, Count = 1, Category = "HarvestedFruits" } end
    pcall(function() sb:Fire(uid, items, "") end)
    task.wait(1)   -- tunggu inventory ke-update (replikasi) sebelum verifikasi
    Farm._scriptSentIds = Farm._scriptSentIds or {}
    local sentN = 0
    for _, e in ipairs(picked) do
        if not fidInBag(e.fid) then   -- beneran ilang -> kekirim
            Farm._mailSent[e.fid] = true; Farm._mailSentVal[e.fid] = e.val; Farm._scriptSentIds[e.fid] = true
            sentN = sentN + 1
        end
        -- masih di tas -> JANGAN ditandai sent, biar dicoba lagi panggilan berikutnya
    end
    if sentN == 0 then return false, "kirim gagal, coba lagi (cooldown?)", cumVal() end
    return true, sentN, cumVal()
end

